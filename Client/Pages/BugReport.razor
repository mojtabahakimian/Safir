@page "/bug-report"
@using Safir.Shared.Models.BugReport
@using Safir.Client.Services
@using MudBlazor
@inject BugReportApiService BugReportApi
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>گزارش خطای نرم‌افزار</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-16">
    <MudPaper Elevation="3" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">گزارش خطای نرم‌افزار</MudText>
        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-6">
            لطفاً اطلاعات زیر را به دقت تکمیل کنید تا بتوانیم مشکل را بررسی و برطرف کنیم.
        </MudText>

        @if (_isSubmitting)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }

        <MudForm Model="@_model" @ref="_form" IsValidChanged="OnValidChanged">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Color="Color.Primary">اطلاعات کاربری (اختیاری)</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.CustomerName" Label="نام مشتری / شرکت" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ContactInfo" Label="تلفن تماس" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Color="Color.Primary">جزئیات مشکل</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Severity" Label="شدت مشکل" Required="true" RequiredError="شدت مشکل الزامی است." Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Low")">کم - اختلال جزئی</MudSelectItem>
                        <MudSelectItem Value="@("Medium")">متوسط - کار را کند کرده است</MudSelectItem>
                        <MudSelectItem Value="@("High")">زیاد - بخشی از سیستم کار نمی‌کند</MudSelectItem>
                        <MudSelectItem Value="@("Critical")">بحرانی - سیستم کاملاً متوقف شده است</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ModuleName" Label="محل بروز خطا (مثال: سبد خرید)" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.UserDescription" Label="شرح کلی مشکل" Required="true" RequiredError="شرح مشکل الزامی است." Lines="3" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.ReproduceSteps" Label="مراحل تکرار خطا (قدم به قدم)" Required="true" RequiredError="مراحل تکرار خطا الزامی است." Lines="4" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ExpectedResult" Label="نتیجه مورد انتظار" Required="true" RequiredError="نتیجه مورد انتظار الزامی است." Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ActualResult" Label="نتیجه واقعی (خطا)" Required="true" RequiredError="نتیجه واقعی الزامی است." Lines="3" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-center mt-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Disabled="@(_isSubmitting || !_isValid)" OnClick="SubmitForm">
                        @if (_isSubmitting)
                        {
                            <MudProgressCircular Class="ms-n1 me-2" Size="Size.Small" Indeterminate="true" />
                            <MudText>در حال ارسال...</MudText>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Send" Class="me-2" />
                            <MudText>ارسال گزارش</MudText>
                        }
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = new();
    private BugReportDto _model = new();
    private bool _isValid;
    private bool _isSubmitting;

    protected override void OnInitialized()
    {
        try
        {
            var version = System.Reflection.Assembly.GetExecutingAssembly().GetName().Version;
            _model.AppVersion = version?.ToString() ?? "Unknown";
            _model.FrontendVersion = _model.AppVersion;
        }
        catch { }
    }

    private void OnValidChanged(bool isValid)
    {
        _isValid = isValid;
    }

    private async Task SubmitForm()
    {
        await _form.Validate();

        if (!_form.IsValid)
        {
            Snackbar.Add("لطفاً فیلدهای الزامی را به درستی تکمیل کنید.", Severity.Warning);
            return;
        }

        if (_isSubmitting) return; // Prevent double submit

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            // Populate technical diagnostics from JS
            var diagnostics = await JSRuntime.InvokeAsync<DiagnosticsInfo>("appDiagnostics.getDiagnosticsInfo");
            if (diagnostics != null)
            {
                _model.BrowserInfo = diagnostics.BrowserInfo;
                _model.OperatingSystem = diagnostics.OperatingSystem;
                _model.ScreenSize = diagnostics.ScreenSize;
                _model.UserAgent = diagnostics.UserAgent;
                _model.PageUrl = diagnostics.PageUrl;
                _model.Route = diagnostics.Route;
            }

            var response = await BugReportApi.SubmitBugReportAsync(_model);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("گزارش خطای شما با موفقیت ثبت شد. از همکاری شما سپاسگزاریم.", Severity.Success);
                _model = new BugReportDto(); // Reset form
                await _form.ResetAsync();

                // Optional: navigate away or stay on page
                // NavigationManager.NavigateTo("/");
            }
            else
            {
                Snackbar.Add("متأسفانه خطایی در ثبت گزارش رخ داد. لطفاً مجدداً تلاش کنید.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطای سیستمی: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private class DiagnosticsInfo
    {
        public string BrowserInfo { get; set; } = "";
        public string OperatingSystem { get; set; } = "";
        public string ScreenSize { get; set; } = "";
        public string UserAgent { get; set; } = "";
        public string PageUrl { get; set; } = "";
        public string Route { get; set; } = "";
    }
}
