@page "/bug-report"
@using Safir.Shared.Models.BugReport
@using Safir.Client.Services
@using MudBlazor
@inject BugReportApiService BugReportApi
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<PageTitle>گزارش خطای نرم‌افزار</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-16">
    <MudPaper Elevation="3" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">گزارش خطای نرم‌افزار</MudText>
        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-6">
            لطفاً اطلاعات زیر را به دقت تکمیل کنید تا بتوانیم مشکل را بررسی و برطرف کنیم.
        </MudText>

        @if (_isSubmitting)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }

        <MudForm Model="@_model" @ref="_form" IsValidChanged="OnValidChanged">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Color="Color.Primary">اطلاعات سیستم</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.AppVersion" Label="نسخه نرم‌افزار حسابداری (ERP)" Variant="Variant.Outlined" HelperText="مثال: 14.5.2" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Color="Color.Primary">اطلاعات کاربری (اختیاری)</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.CustomerName" Label="نام مشتری / شرکت" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ContactInfo" Label="تلفن تماس" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Color="Color.Primary">جزئیات مشکل</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Severity" Label="شدت مشکل" Required="true" RequiredError="شدت مشکل الزامی است." Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Low")">کم - اختلال جزئی</MudSelectItem>
                        <MudSelectItem Value="@("Medium")">متوسط - کار را کند کرده است</MudSelectItem>
                        <MudSelectItem Value="@("High")">زیاد - بخشی از سیستم کار نمی‌کند</MudSelectItem>
                        <MudSelectItem Value="@("Critical")">بحرانی - سیستم کاملاً متوقف شده است</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Category" Label="در کدام بخش مشکل دارید؟" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("ورود و حساب کاربری")">ورود و حساب کاربری</MudSelectItem>
                        <MudSelectItem Value="@("فرآیند خرید و سبد خرید")">فرآیند خرید و سبد خرید</MudSelectItem>
                        <MudSelectItem Value="@("حقوق و دستمزد")">حقوق و دستمزد</MudSelectItem>
                        <MudSelectItem Value="@("تعریف مشتریان")">تعریف مشتریان</MudSelectItem>
                        <MudSelectItem Value="@("گزارش‌ها")">گزارش‌ها</MudSelectItem>
                        <MudSelectItem Value="@("سایر موارد")">سایر موارد (لطفاً در شرح توضیح دهید)</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.UserDescription" Label="به زبان ساده، مشکل چیست؟" HelperText="مثال: وقتی دکمه تایید خرید رو میزنم، صفحه سفید میشه." Required="true" RequiredError="شرح مشکل الزامی است." Lines="3" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" Class="py-1">
                    <MudCheckBox @bind-Value="_model.HappensAlways" Label="آیا هر بار که امتحان می‌کنید، دقیقاً همین اتفاق می‌افتد؟" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" Class="py-1">
                    <MudCheckBox @bind-Value="_model.IsBlocking" Label="آیا این مشکل باعث توقف کامل کار شما شده است؟ (مثلاً امکان ثبت هیچ سندی را ندارید)" Color="Color.Error" />
                </MudItem>
                <MudItem xs="12" Class="py-1">
                    <MudCheckBox @bind-Value="_model.HasRecentChanges" Label="آیا اخیراً تغییری در سیستم عامل، شبکه یا اینترنت خود داده‌اید؟" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" Class="py-1">
                    <MudCheckBox @bind-Value="_model.TestedOnAnotherDevice" Label="آیا روی سیستم دیگری هم چک کردید و همین مشکل وجود داشت؟" Color="Color.Primary" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.ReproduceSteps" Label="شما دقیقا چه کارهایی کردید که به خطا خوردید؟" HelperText="مثال: ۱- رفتم تو بخش مشتریان ۲- روی دکمه جدید کلیک کردم ۳- نام رو نوشتم ۴- وقتی ثبت زدم خطا داد" Required="true" RequiredError="مراحل تکرار خطا الزامی است." Lines="4" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ExpectedResult" Label="انتظار داشتید چه اتفاقی بیفتد؟" HelperText="مثال: انتظار داشتم پیام 'مشتری با موفقیت ثبت شد' رو ببینم." Required="true" RequiredError="نتیجه مورد انتظار الزامی است." Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ActualResult" Label="اما به جای آن چه اتفاقی افتاد؟" HelperText="مثال: یه پیام خطای قرمز رنگ با متن انگلیسی نشون داد." Required="true" RequiredError="نتیجه واقعی الزامی است." Lines="3" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-center mt-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Disabled="@(_isSubmitting || !_isValid)" OnClick="SubmitForm">
                        @if (_isSubmitting)
                        {
                            <MudProgressCircular Class="ms-n1 me-2" Size="Size.Small" Indeterminate="true" />
                            <MudText>در حال ارسال...</MudText>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Send" Class="me-2" />
                            <MudText>ارسال گزارش</MudText>
                        }
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = new();
    private BugReportDto _model = new();
    private bool _isValid;
    private bool _isSubmitting;
    private string _frontendVersion = "Unknown";

    protected override void OnInitialized()
    {
        try
        {
            var version = System.Reflection.Assembly.GetExecutingAssembly().GetName().Version;
            _frontendVersion = version?.ToString() ?? "Unknown";
        }
        catch (Exception)
        {
            _frontendVersion = "Unknown";
        }
        _model = CreateFreshModel();
    }

    // Centralises model creation so FrontendVersion is always set — both on init and after reset.
    private BugReportDto CreateFreshModel() => new BugReportDto { FrontendVersion = _frontendVersion };

    private void OnValidChanged(bool isValid)
    {
        _isValid = isValid;
    }

    private async Task SubmitForm()
    {
        // Guard must be first — before any await — to be truly race-free.
        if (_isSubmitting) return;

        await _form.Validate();
        if (!_form.IsValid)
        {
            Snackbar.Add("لطفاً فیلدهای الزامی را به درستی تکمیل کنید.", Severity.Warning);
            return;
        }

        _isSubmitting = true;
        StateHasChanged(); // show progress bar before first await

        try
        {
            // Diagnostics are supplementary metadata; a JS failure must never block the report.
            try
            {
                var diagnostics = await JSRuntime.InvokeAsync<DiagnosticsInfo>("appDiagnostics.getDiagnosticsInfo");
                if (diagnostics != null)
                {
                    _model.BrowserInfo = diagnostics.BrowserInfo;
                    _model.OperatingSystem = diagnostics.OperatingSystem;
                    _model.ScreenSize = diagnostics.ScreenSize;
                    _model.UserAgent = diagnostics.UserAgent;
                    _model.PageUrl = diagnostics.PageUrl;
                    _model.Route = diagnostics.Route;
                }
            }
            catch { /* proceed without diagnostics */ }

            var response = await BugReportApi.SubmitBugReportAsync(_model);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("گزارش خطای شما با موفقیت ثبت شد. از همکاری شما سپاسگزاریم.", Severity.Success);
                _model = CreateFreshModel();
                _isValid = false; // re-disable button until user fills the fresh form
                await _form.ResetAsync();
            }
            else
            {
                string errorMessage = "متأسفانه خطایی در ثبت گزارش رخ داد. لطفاً مجدداً تلاش کنید.";
                try
                {
                    var body = await response.Content.ReadAsStringAsync();
                    if (!string.IsNullOrWhiteSpace(body))
                        errorMessage = body.Trim('"');
                }
                catch { }
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطای سیستمی: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class DiagnosticsInfo
    {
        public string BrowserInfo { get; set; } = "";
        public string OperatingSystem { get; set; } = "";
        public string ScreenSize { get; set; } = "";
        public string UserAgent { get; set; } = "";
        public string PageUrl { get; set; } = "";
        public string Route { get; set; } = "";
    }
}
