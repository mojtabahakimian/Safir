@page "/production-reports"
@using Safir.Shared.Models.Production
@using MudBlazor
@inject Safir.Client.Services.IProductionReportApiService ApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Safir.Client.Pages.Salary.Tabs

<style>
    /* ═════════ استایل‌های نوار تب اختصاصی (Segmented Tabs) ═════════ */
    .p2-tab-bar {
        display: flex;
        background-color: var(--p2-bg-hover, #f1f5f9);
        padding: 6px;
        border-radius: 16px;
        gap: 6px;
        margin-bottom: 24px;
        border: 1px solid var(--p2-border, #e2e8f0);
        /* تنظیمات موبایل برای اسکرول افقی نرم */
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none; /* فایرفاکس */
    }

        .p2-tab-bar::-webkit-scrollbar {
            display: none; /* کروم و سافاری */
        }

    .p2-tab-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.95rem;
        color: var(--p2-text-muted, #64748b);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: none;
        background: transparent;
        white-space: nowrap;
    }

        .p2-tab-btn:hover {
            color: var(--p2-primary, #2563eb);
            background-color: rgba(37, 99, 235, 0.05);
        }

        .p2-tab-btn.active {
            background-color: #ffffff;
            color: var(--p2-primary, #2563eb);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

    .p2-tab-icon {
        font-size: 1.2rem;
        margin-bottom: 2px;
    }


    /* ═════════ استایل‌های کارت مدیریتی ═════════ */
    .manager-card {
        background: var(--p2-bg-white, #ffffff);
        border: 1px solid var(--p2-border, #e2e8f0);
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
    }

        .manager-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08);
            border-color: var(--p2-primary-border, #93c5fd);
        }

    .mc-indicator {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background-color: var(--p2-success-text, #059669);
    }

        .mc-indicator.has-note {
            background-color: var(--p2-warning-text, #d97706);
        }

    .mc-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed var(--p2-border-light, #f1f5f9);
        padding-bottom: 12px;
        margin-bottom: 12px;
        padding-right: 8px;
    }

    .mc-company {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--p2-text-main, #1e293b);
    }

    .mc-date {
        font-family: 'Courier New', monospace;
        font-size: 0.9rem;
        color: var(--p2-text-muted, #64748b);
        background: var(--p2-bg-main, #f8fafc);
        padding: 4px 10px;
        border-radius: 20px;
        font-weight: bold;
    }

    .mc-stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 12px;
    }

    .mc-stat-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 14px 10px;
        border-radius: 12px;
    }

        .mc-stat-box.in {
            background: rgba(3, 169, 244, 0.05);
            border: 1px solid rgba(3, 169, 244, 0.1);
        }

        .mc-stat-box.out {
            background: rgba(76, 175, 80, 0.05);
            border: 1px solid rgba(76, 175, 80, 0.1);
        }

        .mc-stat-box.kpi {
            background: rgba(156, 39, 176, 0.05);
            border: 1px solid rgba(156, 39, 176, 0.1);
        }

    .mc-stat-label {
        font-size: 0.85rem;
        color: var(--p2-text-muted, #64748b);
        font-weight: 800;
        margin-bottom: 6px;
    }

    .mc-stat-value {
        font-size: 1.75rem;
        font-weight: 900;
        font-family: 'Courier New', monospace;
        line-height: 1;
        letter-spacing: -0.5px;
    }

    .mc-stat-subvalue {
        font-size: 0.85rem;
        color: var(--p2-text-muted, #64748b);
        margin-top: 6px;
        font-weight: bold;
    }

    .mc-stat-unit {
        font-size: 0.85rem;
        font-weight: 600;
        margin-right: 4px;
        opacity: 0.9;
    }

    .mc-speed-row {
        display: flex;
        justify-content: space-around;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 12px 8px;
        margin-bottom: 12px;
    }

    .mc-speed-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        font-size: 0.85rem;
        color: #475569;
        font-weight: 700;
    }

    .mc-speed-val {
        font-weight: 900;
        font-size: 1.4rem;
        color: #0f172a;
        font-family: 'Courier New', monospace;
        margin-top: 4px;
    }

    .mc-details {
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--p2-text-muted, #64748b);
        padding: 0 8px;
    }

    .mc-detail-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px dashed #e2e8f0;
        padding-bottom: 8px;
    }

        .mc-detail-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .mc-time-badge {
        background: #e2e8f0;
        color: #334155;
        padding: 4px 8px;
        border-radius: 6px;
        font-family: 'Courier New', monospace;
        font-weight: 900;
        font-size: 0.85rem;
    }

    .mc-desc-box {
        margin-top: 12px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-right: 4px solid #f59e0b;
        padding: 12px;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #92400e;
        line-height: 1.6;
    }

    /* 📱 ریسپانسیو موبایل */
    @@media (max-width: 600px) {
        .p2-tab-btn {
            padding: 10px 16px;
            font-size: 0.85rem;
        }

        .mc-stats-grid {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .mc-stat-box {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
        }

        .mc-stat-label {
            margin-bottom: 0;
            font-size: 0.9rem;
        }

        .mc-stat-value {
            font-size: 1.55rem;
        }

        .mc-speed-val {
            font-size: 1.35rem;
        }

        .mc-stat-subvalue {
            margin-top: 0;
        }

        .mc-speed-row {
            flex-direction: row;
            justify-content: space-between;
            padding: 12px 16px;
        }

        .mc-speed-item {
            align-items: flex-start;
        }
    }
</style>

<div class="pay2-tab-container pb-10" style="max-width: 1200px; margin: 0 auto;">
    @if (!_isDataLoaded)
    {
        <div class="d-flex justify-center align-center" style="height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else
    {
        <!-- 🚀 نوار تب اختصاصی و کاملاً خوانا (جایگزین MudTabs) -->
        <div class="p2-tab-bar">
            <button class="p2-tab-btn @(_activeTab == 0 ? "active" : "")" @onclick="() => _activeTab = 0">
                <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Class="p2-tab-icon" /> پیش‌خوان و آمار
            </button>
            <button class="p2-tab-btn @(_activeTab == 1 ? "active" : "")" @onclick="() => _activeTab = 1">
                <MudIcon Icon="@Icons.Material.Outlined.AddCircleOutline" Class="p2-tab-icon" /> ثبت گزارش جدید
            </button>
            <button class="p2-tab-btn @(_activeTab == 2 ? "active" : "")" @onclick="() => _activeTab = 2">
                <MudIcon Icon="@Icons.Material.Outlined.History" Class="p2-tab-icon" /> دفتر گزارشات
            </button>
        </div>

        <!-- ═════════════════════ تب 0: داشبورد ═════════════════════ -->
        @if (_activeTab == 0)
        {
            <div class="animate-fade-in">
                <MudGrid Class="mb-6">
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl d-flex align-center pay2-form-card" Style="border-left: 6px solid var(--mud-palette-info) !important;">
                            <div class="pa-3 rounded-lg ml-4" style="background-color: rgba(3, 169, 244, 0.1);">
                                <MudIcon Icon="@Icons.Material.Outlined.WaterDrop" Color="Color.Info" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="text-muted d-block mb-1" Style="font-weight: bold;">کل آب‌پنیر دریافتی (تغلیظ)</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 900; letter-spacing: 0.5px;">@TotalWheyQty.ToString("N0") <span style="font-size: 14px; font-weight: normal;" class="text-muted">لیتر</span></MudText>
                            </div>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl d-flex align-center pay2-form-card" Style="border-left: 6px solid var(--mud-palette-success) !important;">
                            <div class="pa-3 rounded-lg ml-4" style="background-color: rgba(76, 175, 80, 0.1);">
                                <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Color="Color.Success" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="text-muted d-block mb-1" Style="font-weight: bold;">کل پودر خروجی (اسپری)</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 900; letter-spacing: 0.5px;">@TotalPowderQty.ToString("N0") <span style="font-size: 14px; font-weight: normal;" class="text-muted">کیلوگرم</span></MudText>
                            </div>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="12" md="4">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl d-flex align-center pay2-form-card" Style="border-left: 6px solid var(--mud-palette-primary) !important;">
                            <div class="pa-3 rounded-lg ml-4" style="background-color: rgba(var(--mud-palette-primary-rgb), 0.1);">
                                <MudIcon Icon="@Icons.Material.Outlined.Assessment" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="text-muted d-block mb-1" Style="font-weight: bold;">تعداد کل گزارشات ثبت‌شده</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 900; letter-spacing: 0.5px;">@_reports.Count <span style="font-size: 14px; font-weight: normal;" class="text-muted">شیفت کاری</span></MudText>
                            </div>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudGrid>
                    <MudItem xs="12" md="7">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl pay2-form-card">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-4">نمودار حجم تولید روزهای اخیر</MudText>
                            @if (_chartSeries.Any() && _chartSeries[0].Data.Any(v => v > 0))
                            {
                                <MudChart ChartType="ChartType.Bar" ChartSeries="@_chartSeries" XAxisLabels="@_chartXLabels" Width="100%" Height="300px" ChartOptions="@_chartOptions" />
                            }
                            else
                            {
                                <div class="d-flex align-center justify-center text-muted" style="height: 300px;">
                                    <MudText Typo="Typo.body2">داده‌ای برای نمایش نمودار میله‌ای وجود ندارد.</MudText>
                                </div>
                            }
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="5">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl pay2-form-card d-flex flex-column justify-space-between h-100">
                            <div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-4">نسبت بهره‌وری کارخانه</MudText>
                                <MudText Typo="Typo.body2" Class="text-muted mb-6">درصد تبدیل مایع به پودر بر اساس کل ورودی دیتابیس.</MudText>
                            </div>
                            <div class="d-flex flex-column justify-center align-center mb-4">
                                @if (TotalWheyQty > 0)
                                {
                                    <MudChart ChartType="ChartType.Donut" Width="220px" Height="220px" InputData="@_donutData" InputLabels="@_donutLabels" ChartOptions="@_chartOptions" />

                                    <div class="mt-4 text-center">
                                        @{
                                            var efficiency = TotalWheyQty > 0 ? ((decimal)TotalPowderQty / (decimal)TotalWheyQty * 100) : 0;
                                            var ratio = TotalPowderQty > 0 ? ((decimal)TotalWheyQty / (decimal)TotalPowderQty) : 0;
                                        }
                                        <MudText Typo="Typo.h6" Color="Color.Success" Style="font-weight: bold;">
                                            راندمان کل: @efficiency.ToString("N2")٪
                                        </MudText>
                                        <MudText Typo="Typo.body2" Class="text-muted">
                                            (هر @ratio.ToString("N2") لیتر آب‌پنیر = ۱ کیلوگرم پودر)
                                        </MudText>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-center justify-center text-muted" style="height: 220px;">
                                        <MudText Typo="Typo.body2">داده‌ای برای تحلیل نسبت تبدیل وجود ندارد.</MudText>
                                    </div>
                                }
                            </div>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </div>
        }

        <!-- ═════════════════════ تب 1: ثبت جدید ═════════════════════ -->
        @if (_activeTab == 1)
        {
            <div class="animate-fade-in">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl pay2-form-card">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Outlined.Assignment" Color="Color.Primary" Class="ml-2" />
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">ثبت گزارش تولید روزانه</MudText>
                    </div>

                    <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-lg mb-6 pay2-input-group-bg">
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <div class="d-flex align-center mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" Class="ml-1 text-muted" />
                                    <MudText Typo="Typo.body2" Class="text-muted" Style="font-weight: bold;">تاریخ گزارش (شمسی):</MudText>
                                </div>
                                <Pay2NumericInput Value="@_shamsiDateStr"
                                                  ValueChanged="@((string? val) => _shamsiDateStr = val)"
                                                  InputMode="Pay2NumericInput.NumericInputMode.PersianDate"
                                                  Placeholder="مثال: 14050327" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="d-flex align-center mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Business" Size="Size.Small" Class="ml-1 text-muted" />
                                    <MudText Typo="Typo.body2" Class="text-muted" Style="font-weight: bold;">شرکت آب‌پنیر:</MudText>
                                </div>
                                <MudTextField @bind-Value="Model.WheyCompany"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Placeholder="نام شرکت را وارد کنید..." />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <MudGrid Class="mb-6">
                        <MudItem xs="12" md="6">
                            <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-lg h-100 pay2-card-blue">
                                <div class="d-flex align-center mb-6">
                                    <div style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--mud-palette-info);" class="ml-2"></div>
                                    <MudText Typo="Typo.subtitle1" Color="Color.Info" Style="font-weight: bold;">بخش تغلیظ (Concentration Unit)</MudText>
                                </div>
                                <MudGrid>
                                    <MudItem xs="12" sm="6">
                                        <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">شروع فرآیند:</MudText>
                                        <MudTimePicker @bind-Time="Model.ConcentrationStart" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">پایان فرآیند:</MudText>
                                        <MudTimePicker @bind-Time="Model.ConcentrationEnd" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">مقدار آبپنیر دریافتی (لیتر):</MudText>
                                        <MudNumericField @bind-Value="Model.ConcentrationWheyQty" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-lg h-100 pay2-card-green">
                                <div class="d-flex align-center mb-6">
                                    <div style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--mud-palette-success);" class="ml-2"></div>
                                    <MudText Typo="Typo.subtitle1" Color="Color.Success" Style="font-weight: bold;">بخش اسپری (Spray Dryer Unit)</MudText>
                                </div>
                                <MudGrid>
                                    <MudItem xs="12" sm="6">
                                        <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">شروع اسپری:</MudText>
                                        <MudTimePicker @bind-Time="Model.SprayStart" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">پایان اسپری:</MudText>
                                        <MudTimePicker @bind-Time="Model.SprayEnd" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">مقدار پودر خروجی (کیلوگرم):</MudText>
                                        <MudNumericField @bind-Value="Model.SprayPowderQty" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudGrid Class="mb-2">
                        <MudItem xs="12" md="8">
                            <MudText Typo="Typo.body2" Style="font-weight: bold;" Class="mb-2 text-muted">توضیحات و گزارش شیفت:</MudText>
                            <MudTextField @bind-Value="Model.Description" Variant="Variant.Outlined" Lines="3" Placeholder="توضیحات مربوط به خاموشی‌ها، ایرادات فنی، شستشوی واحد CIP یا ناخالصی‌ها..." />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudText Typo="Typo.body2" Style="font-weight: bold;" Class="mb-2 text-muted">عدد کنتور نهایی:</MudText>
                            <MudTextField @bind-Value="Model.CounterNumber" Variant="Variant.Outlined" Placeholder="مثال: ۲۴۵۸۹" />
                        </MudItem>
                    </MudGrid>

                    <div class="d-flex justify-start mt-6">
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="rounded-xl px-8 py-2" OnClick="Submit" Disabled="_isProcessing" StartIcon="@Icons.Material.Outlined.Save">
                            @if (_isProcessing)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            }
                            else
                            {
                                <span style="font-weight: bold;">ثبت قطعی گزارش</span>
                            }
                        </MudButton>
                    </div>
                </MudPaper>
            </div>
        }

        <!-- ═════════════════════ تب 2: تاریخچه ═════════════════════ -->
        @if (_activeTab == 2)
        {
            <div class="animate-fade-in">
                <MudTextField @bind-Value="_searchString" Placeholder="جستجو در نام شرکت یا توضیحات..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mb-6 bg-white" Variant="Variant.Outlined" Immediate="true" />

                @if (!FilteredReports.Any())
                {
                    <div class="d-flex flex-column align-center justify-center text-muted" style="height: 300px;">
                        <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Class="mb-3" />
                        <MudText Typo="Typo.h6">هیچ گزارشی یافت نشد.</MudText>
                    </div>
                }
                else
                {
                    <div style="height: calc(100vh - 280px); overflow-y: auto; padding-right: 4px; padding-bottom: 20px;">
                        <Virtualize Items="FilteredReports.ToList()" Context="report">
                            @{
                                var concE = GetElapsedTime(report.ConcentrationStart, report.ConcentrationEnd);
                                var sprayE = GetElapsedTime(report.SprayStart, report.SprayEnd);

                                var eff = report.ConcentrationWheyQty > 0 ? ((decimal)(report.SprayPowderQty ?? 0) / (decimal)(report.ConcentrationWheyQty ?? 0) * 100) : 0;
                                var ratio = report.SprayPowderQty > 0 ? ((decimal)(report.ConcentrationWheyQty ?? 0) / (decimal)(report.SprayPowderQty ?? 0)) : 0;

                                var concSpeed = (concE.HasValue && concE.Value.TotalHours > 0 && report.ConcentrationWheyQty > 0) ? (report.ConcentrationWheyQty.Value / (decimal)concE.Value.TotalHours) : 0;
                                var spraySpeed = (sprayE.HasValue && sprayE.Value.TotalHours > 0 && report.SprayPowderQty > 0) ? (report.SprayPowderQty.Value / (decimal)sprayE.Value.TotalHours) : 0;

                                bool hasNote = !string.IsNullOrWhiteSpace(report.Description);
                            }

                            <div class="manager-card">
                                <div class="mc-indicator @(hasNote ? "has-note" : "")"></div>

                                <div class="mc-header">
                                    <div>
                                        <div class="mc-company">@(string.IsNullOrWhiteSpace(report.WheyCompany) ? "بدون نام شرکت" : report.WheyCompany)</div>
                                    </div>
                                    <div style="display:flex; align-items:center; gap: 8px;">
                                        @if (hasNote)
                                        {
                                            <MudTooltip Text="یادداشت/هشدار ثبت شده است">
                                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                                            </MudTooltip>
                                        }
                                        <div class="mc-date">@GetShamsiDateString(report.ReportDate)</div>
                                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                                            <MudMenuItem OnClick="() => EditReport(report)"><MudIcon Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" Class="mr-2" Color="Color.Info" /> ویرایش</MudMenuItem>
                                            <MudMenuItem OnClick="() => DeleteReport(report)"><MudIcon Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" Class="mr-2" Color="Color.Error" /> حذف</MudMenuItem>
                                        </MudMenu>
                                    </div>
                                </div>

                                <div class="mc-stats-grid">
                                    <div class="mc-stat-box in">
                                        <div class="mc-stat-label">آب‌پنیر ورودی (تغلیظ)</div>
                                        <div style="color: #0288d1;">
                                            <span class="mc-stat-value">@(report.ConcentrationWheyQty?.ToString("N0") ?? "0")</span>
                                            <span class="mc-stat-unit">L</span>
                                        </div>
                                    </div>

                                    <div class="mc-stat-box out">
                                        <div class="mc-stat-label">پودر خروجی (اسپری)</div>
                                        <div style="color: #2e7d32;">
                                            <span class="mc-stat-value">@(report.SprayPowderQty?.ToString("N0") ?? "0")</span>
                                            <span class="mc-stat-unit">Kg</span>
                                        </div>
                                    </div>

                                    <div class="mc-stat-box kpi">
                                        <div class="mc-stat-label">راندمان عملکرد</div>
                                        <div style="color: #7b1fa2; display:flex; flex-direction:column; justify-content:center; align-items:center;">
                                            <div>
                                                <span class="mc-stat-value">@eff.ToString("N1")</span>
                                                <span class="mc-stat-unit">٪</span>
                                            </div>
                                            @if (ratio > 0)
                                            {
                                                <div class="mc-stat-subvalue">۱ به @ratio.ToString("N1")</div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="mc-speed-row">
                                    <div class="mc-speed-item" title="سرعت متوسط تغلیظ">
                                        <span>سرعت تغلیظ</span>
                                        <div>
                                            <span class="mc-speed-val">@(concSpeed > 0 ? concSpeed.ToString("N0") : "-")</span>
                                            <span style="font-size:0.8rem; font-weight:bold; opacity:0.8;">L/h</span>
                                        </div>
                                    </div>
                                    <div style="width:1px; background:#cbd5e1; margin: 0 10px;"></div>
                                    <div class="mc-speed-item" title="سرعت متوسط تولید پودر">
                                        <span>سرعت اسپری</span>
                                        <div>
                                            <span class="mc-speed-val">@(spraySpeed > 0 ? spraySpeed.ToString("N0") : "-")</span>
                                            <span style="font-size:0.8rem; font-weight:bold; opacity:0.8;">Kg/h</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mc-details">
                                    <div class="mc-detail-item">
                                        <div style="display:flex; align-items:center; gap:6px;">
                                            <MudIcon Icon="@Icons.Material.Outlined.WaterDrop" Size="Size.Small" Color="Color.Info" />
                                            <span>زمان کارکرد تغلیظ:</span>
                                        </div>
                                        <div>
                                            <span dir="ltr">@(report.ConcentrationStart?.ToString(@"hh\:mm") ?? "-")</span> الی <span dir="ltr">@(report.ConcentrationEnd?.ToString(@"hh\:mm") ?? "-")</span>
                                            @if (concE.HasValue)
                                            {
                                                <span class="mc-time-badge ml-1">(@FormatElapsedTime(concE))</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="mc-detail-item">
                                        <div style="display:flex; align-items:center; gap:6px;">
                                            <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Size="Size.Small" Color="Color.Success" />
                                            <span>زمان کارکرد اسپری:</span>
                                        </div>
                                        <div>
                                            <span dir="ltr">@(report.SprayStart?.ToString(@"hh\:mm") ?? "-")</span> الی <span dir="ltr">@(report.SprayEnd?.ToString(@"hh\:mm") ?? "-")</span>
                                            @if (sprayE.HasValue)
                                            {
                                                <span class="mc-time-badge ml-1">(@FormatElapsedTime(sprayE))</span>
                                            }
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(report.CounterNumber))
                                    {
                                        <div class="mc-detail-item" style="border-bottom:none;">
                                            <div style="display:flex; align-items:center; gap:6px;">
                                                <MudIcon Icon="@Icons.Material.Outlined.Numbers" Size="Size.Small" />
                                                <span>شماره کنتور نهایی:</span>
                                            </div>
                                            <span class="mc-stat-value" style="font-size: 1.25rem;">
                                                @(decimal.TryParse(report.CounterNumber, out var c) ? c.ToString("N0") : report.CounterNumber)
                                            </span>
                                        </div>
                                    }
                                </div>

                                @if (hasNote)
                                {
                                    <div class="mc-desc-box">
                                        <div style="font-weight:bold; margin-bottom:4px; display:flex; align-items:center; gap:4px;">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" /> یادداشت شیفت:
                                        </div>
                                        @report.Description
                                    </div>
                                }
                            </div>
                        </Virtualize>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool _isDataLoaded = false;
    private int _activeTab = 0;
    private bool _isProcessing = false;
    private string _searchString = string.Empty;

    private string? _shamsiDateStr;
    private List<ProductionReportDto> _reports = new();
    private ProductionReportDto Model = new();

    private decimal TotalWheyQty => _reports.Sum(x => x.ConcentrationWheyQty ?? 0);
    private decimal TotalPowderQty => _reports.Sum(x => x.SprayPowderQty ?? 0);

    private List<ChartSeries> _chartSeries = new();
    private string[] _chartXLabels = Array.Empty<string>();
    private double[] _donutData = Array.Empty<double>();
    private string[] _donutLabels = new[] { "پودر تولیدی (کیلوگرم)", "آب‌پنیر تبخیر شده (لیتر)" };
    private ChartOptions _chartOptions = new();

    private IEnumerable<ProductionReportDto> FilteredReports =>
        string.IsNullOrWhiteSpace(_searchString)
            ? _reports
            : _reports.Where(x =>
                (x.WheyCompany != null && x.WheyCompany.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                (x.Description != null && x.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        _shamsiDateStr = GetTodayShamsi();
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _reports = await ApiService.GetReportsAsync();
            CalculateDashboardStats();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطا در دریافت اطلاعات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDataLoaded = true;
        }
    }

    private void CalculateDashboardStats()
    {
        if (_reports == null || !_reports.Any()) return;

        var topReports = _reports.OrderBy(x => x.ReportDate).TakeLast(5).ToList();
        _chartXLabels = topReports.Select(x => GetShamsiDateStringShort(x.ReportDate)).ToArray();

        _chartSeries = new List<ChartSeries>
        {
            new() { Name = "آبپنیر دریافتی (لیتر)", Data = topReports.Select(x => (double)(x.ConcentrationWheyQty ?? 0)).ToArray() },
            new() { Name = "پودر خروجی (کیلوگرم)", Data = topReports.Select(x => (double)(x.SprayPowderQty ?? 0)).ToArray() }
        };

        if (TotalWheyQty > 0)
        {
            double remainingLiquid = (double)TotalWheyQty - (double)TotalPowderQty;
            _donutData = new double[] { (double)TotalPowderQty, remainingLiquid > 0 ? remainingLiquid : 0 };
            _donutLabels = new[]
            {
                $"پودر تولیدی ({TotalPowderQty.ToString("N0")} کیلوگرم)",
                $"آب‌پنیر تبخیر شده ({(remainingLiquid > 0 ? remainingLiquid : 0).ToString("N0")} لیتر)"
            };
        }
    }

    private TimeSpan? GetElapsedTime(TimeSpan? start, TimeSpan? end)
    {
        if (!start.HasValue || !end.HasValue) return null;
        var elapsed = end.Value - start.Value;
        if (elapsed < TimeSpan.Zero)
            elapsed = elapsed.Add(TimeSpan.FromHours(24));
        return elapsed;
    }

    private string FormatElapsedTime(TimeSpan? elapsed)
    {
        if (!elapsed.HasValue) return "-";
        int hours = (int)elapsed.Value.TotalHours;
        int minutes = elapsed.Value.Minutes;
        return $"{hours}h {minutes:00}m";
    }

    private string GetShamsiDateString(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new System.Globalization.PersianCalendar();
        return $"{pc.GetYear(date.Value):0000}/{pc.GetMonth(date.Value):00}/{pc.GetDayOfMonth(date.Value):00}";
    }

    private string GetShamsiDateStringShort(DateTime? date)
    {
        if (!date.HasValue) return "";
        var pc = new System.Globalization.PersianCalendar();
        return $"{pc.GetMonth(date.Value):00}/{pc.GetDayOfMonth(date.Value):00}";
    }

    private string GetTodayShamsi()
    {
        var pc = new System.Globalization.PersianCalendar();
        var now = DateTime.Now;
        return $"{pc.GetYear(now):0000}{pc.GetMonth(now):00}{pc.GetDayOfMonth(now):00}";
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(Model.WheyCompany) || string.IsNullOrWhiteSpace(_shamsiDateStr))
        {
            Snackbar.Add("تکمیل فیلدهای تاریخ و شرکت اجباری است.", Severity.Warning);
            return;
        }

        try
        {
            _isProcessing = true;

            DateTime parsedDate = DateTime.Now;
            var cleanShamsi = Safir.Shared.Utility.CL_METHODS.FixPersianChars((_shamsiDateStr ?? "").Replace("/", "").Replace("-", ""));
            if (cleanShamsi.Length == 8 && int.TryParse(cleanShamsi.Substring(0, 4), out int year) &&
                int.TryParse(cleanShamsi.Substring(4, 2), out int month) &&
                int.TryParse(cleanShamsi.Substring(6, 2), out int day))
            {
                var pc = new System.Globalization.PersianCalendar();
                try
                {
                    parsedDate = pc.ToDateTime(year, month, day, 0, 0, 0, 0);
                }
                catch { }
            }
            Model.ReportDate = parsedDate;

            await ApiService.SaveReportAsync(Model);
            Snackbar.Add("گزارش با موفقیت ثبت شد.", Severity.Success);

            Model = new ProductionReportDto();
            _shamsiDateStr = GetTodayShamsi();

            await LoadData();
            _activeTab = 2;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطا در ثبت گزارش: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void EditReport(ProductionReportDto report)
    {
        Model = new ProductionReportDto
        {
            Id = report.Id,
            ReportDate = report.ReportDate,
            WheyCompany = report.WheyCompany,
            ConcentrationStart = report.ConcentrationStart,
            ConcentrationEnd = report.ConcentrationEnd,
            ConcentrationWheyQty = report.ConcentrationWheyQty,
            SprayStart = report.SprayStart,
            SprayEnd = report.SprayEnd,
            SprayPowderQty = report.SprayPowderQty,
            CounterNumber = report.CounterNumber,
            Description = report.Description
        };

        if (report.ReportDate.HasValue)
        {
            var pc = new System.Globalization.PersianCalendar();
            _shamsiDateStr = $"{pc.GetYear(report.ReportDate.Value):0000}{pc.GetMonth(report.ReportDate.Value):00}{pc.GetDayOfMonth(report.ReportDate.Value):00}";
        }
        else
        {
            _shamsiDateStr = "";
        }
        _activeTab = 1;
    }

    private async Task DeleteReport(ProductionReportDto report)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "تایید حذف",
            $"آیا از حذف گزارش تولید روز {report.ReportDate?.ToString("yyyy/MM/dd")} اطمینان دارید؟",
            yesText: "بله، حذف شود", cancelText: "انصراف");

        if (confirm == true)
        {
            try
            {
                await ApiService.DeleteReportAsync(report.Id);
                Snackbar.Add("گزارش با موفقیت حذف شد.", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"خطا در حذف گزارش: {ex.Message}", Severity.Error);
            }
        }
    }
}

