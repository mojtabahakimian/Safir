@page "/production-reports"
@using Safir.Shared.Models.Production
@using MudBlazor
@inject Safir.Client.Services.IProductionReportApiService ApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Safir.Client.Pages.Salary.Tabs

<div class="pay2-tab-container pb-10" style="max-width: 1200px; margin: 0 auto;">
    @if (!_isDataLoaded)
    {
        <div class="d-flex justify-center align-center" style="height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else
    {
        <div class="d-flex flex-wrap justify-end mb-6">
            <MudPaper Elevation="0" Class="d-flex flex-wrap rounded-xl pa-1" Style="background-color: #f0f2f5;">
                <MudButton StartIcon="@Icons.Material.Outlined.Dashboard" Class="rounded-xl px-4 py-2"
                           Color="@(_activeTab == 0 ? Color.Primary : Color.Default)"
                           Variant="@(_activeTab == 0 ? Variant.Filled : Variant.Text)"
                           OnClick="() => _activeTab = 0">پیش‌خوان و آمار</MudButton>

                <MudButton StartIcon="@Icons.Material.Outlined.AddCircleOutline" Class="rounded-xl px-4 py-2 mx-1"
                           Color="@(_activeTab == 1 ? Color.Primary : Color.Default)"
                           Variant="@(_activeTab == 1 ? Variant.Filled : Variant.Text)"
                           OnClick="() => _activeTab = 1">ثبت گزارش جدید</MudButton>

                <MudButton StartIcon="@Icons.Material.Outlined.History" Class="rounded-xl px-4 py-2"
                           Color="@(_activeTab == 2 ? Color.Primary : Color.Default)"
                           Variant="@(_activeTab == 2 ? Variant.Filled : Variant.Text)"
                           OnClick="() => _activeTab = 2">تاریخچه و دفتر گزارش</MudButton>
            </MudPaper>
        </div>

        @if (_activeTab == 0)
        {
            <div class="animate-fade-in">
                <MudGrid Class="mb-6">
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl d-flex align-center pay2-form-card" Style="border-left: 6px solid var(--mud-palette-info) !important;">
                            <div class="pa-3 rounded-lg ml-4" style="background-color: rgba(3, 169, 244, 0.1);">
                                <MudIcon Icon="@Icons.Material.Outlined.WaterDrop" Color="Color.Info" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="text-muted d-block mb-1" Style="font-weight: bold;">کل آب‌پنیر دریافتی (تغلیظ)</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 900; letter-spacing: 0.5px;">@TotalWheyQty.ToString("N0") <span style="font-size: 14px; font-weight: normal;" class="text-muted">لیتر</span></MudText>
                            </div>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl d-flex align-center pay2-form-card" Style="border-left: 6px solid var(--mud-palette-success) !important;">
                            <div class="pa-3 rounded-lg ml-4" style="background-color: rgba(76, 175, 80, 0.1);">
                                <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Color="Color.Success" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="text-muted d-block mb-1" Style="font-weight: bold;">کل پودر خروجی (اسپری)</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 900; letter-spacing: 0.5px;">@TotalPowderQty.ToString("N0") <span style="font-size: 14px; font-weight: normal;" class="text-muted">کیلوگرم</span></MudText>
                            </div>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="12" md="4">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl d-flex align-center pay2-form-card" Style="border-left: 6px solid var(--mud-palette-primary) !important;">
                            <div class="pa-3 rounded-lg ml-4" style="background-color: rgba(var(--mud-palette-primary-rgb), 0.1);">
                                <MudIcon Icon="@Icons.Material.Outlined.Assessment" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="text-muted d-block mb-1" Style="font-weight: bold;">تعداد کل گزارشات ثبت‌شده</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 900; letter-spacing: 0.5px;">@_reports.Count <span style="font-size: 14px; font-weight: normal;" class="text-muted">روز رکورد</span></MudText>
                            </div>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudGrid>
                    <MudItem xs="12" md="7">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl pay2-form-card">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-4">نمودار حجم تولید روزهای اخیر</MudText>
                            @if (_chartSeries.Any() && _chartSeries[0].Data.Any(v => v > 0))
                            {
                                <MudChart ChartType="ChartType.Bar" ChartSeries="@_chartSeries" XAxisLabels="@_chartXLabels" Width="100%" Height="300px" ChartOptions="@_chartOptions" />

                                <div class="d-flex flex-wrap gap-2 mt-4 justify-center">
                                    @foreach (var report in _reports.OrderBy(x => x.ReportDate).TakeLast(5))
                                    {
                                        <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">
                                            @GetShamsiDateString(report.ReportDate):
                                            آب‌پنیر @(report.ConcentrationWheyQty?.ToString("N0") ?? "0") -
                                            پودر @(report.SprayPowderQty?.ToString("N0") ?? "0")
                                        </MudChip>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-center justify-center text-muted" style="height: 300px;">
                                    <MudText Typo="Typo.body2">داده‌ای برای نمایش نمودار میله‌ای وجود ندارد.</MudText>
                                </div>
                            }
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="5">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl pay2-form-card d-flex flex-column justify-space-between h-100">
                            <div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-4">نسبت بهره‌وری واحد شیر خشک</MudText>
                                <MudText Typo="Typo.body2" Class="text-muted mb-6">درصد تبدیل مایع به پودر بر اساس کل ورودی دیتابیس کارخانه.</MudText>
                            </div>
                            <div class="d-flex flex-column justify-center align-center mb-4">
                                @if (TotalWheyQty > 0)
                                {
                                    <MudChart ChartType="ChartType.Donut" Width="220px" Height="220px" InputData="@_donutData" InputLabels="@_donutLabels" ChartOptions="@_chartOptions" />

                                    <div class="mt-4 text-center">
                                        @{
                                            var efficiency = TotalWheyQty > 0 ? ((decimal)TotalPowderQty / (decimal)TotalWheyQty * 100) : 0;
                                            var ratio = TotalPowderQty > 0 ? ((decimal)TotalWheyQty / (decimal)TotalPowderQty) : 0;
                                        }
                                        <MudText Typo="Typo.h6" Color="Color.Success" Style="font-weight: bold;">
                                            راندمان: @efficiency.ToString("N2")٪
                                        </MudText>
                                        <MudText Typo="Typo.body2" Class="text-muted">
                                            (هر @ratio.ToString("N2") لیتر آب‌پنیر = ۱ کیلوگرم پودر)
                                        </MudText>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-center justify-center text-muted" style="height: 220px;">
                                        <MudText Typo="Typo.body2">داده‌ای برای تحلیل نسبت تبدیل وجود ندارد.</MudText>
                                    </div>
                                }
                            </div>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </div>
        }

        else if (_activeTab == 1)
        {
            <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl pay2-form-card">
                <div class="d-flex align-center mb-6">
                    <MudIcon Icon="@Icons.Material.Outlined.Assignment" Color="Color.Primary" Class="ml-2" />
                    <MudText Typo="Typo.h6" Style="font-weight: 700;">ثبت گزارش تولید روزانه</MudText>
                </div>

                <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-lg mb-6 pay2-input-group-bg">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <div class="d-flex align-center mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" Class="ml-1 text-muted" />
                                <MudText Typo="Typo.body2" Class="text-muted" Style="font-weight: bold;">تاریخ گزارش (شمسی):</MudText>
                            </div>
                            <Pay2NumericInput Value="@_shamsiDateStr"
                                              ValueChanged="@((string? val) => _shamsiDateStr = val)"
                                              InputMode="Pay2NumericInput.NumericInputMode.PersianDate"
                                              Placeholder="مثال: 14050327" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <div class="d-flex align-center mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Business" Size="Size.Small" Class="ml-1 text-muted" />
                                <MudText Typo="Typo.body2" Class="text-muted" Style="font-weight: bold;">شرکت آب‌پنیر:</MudText>
                            </div>
                            <MudTextField @bind-Value="Model.WheyCompany"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="نام شرکت را وارد کنید..." />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudGrid Class="mb-6">
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-lg h-100 pay2-card-blue">
                            <div class="d-flex align-center mb-6">
                                <div style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--mud-palette-info);" class="ml-2"></div>
                                <MudText Typo="Typo.subtitle1" Color="Color.Info" Style="font-weight: bold;">بخش تغلیظ (Concentration Unit)</MudText>
                            </div>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">شروع فرآیند:</MudText>
                                    <MudTimePicker @bind-Time="Model.ConcentrationStart" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">پایان فرآیند:</MudText>
                                    <MudTimePicker @bind-Time="Model.ConcentrationEnd" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">مقدار آبپنیر دریافتی:</MudText>
                                    <MudNumericField @bind-Value="Model.ConcentrationWheyQty" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="مثال: ۱۵۰۰۰" Adornment="Adornment.End" AdornmentText="لیتر" AdornmentColor="Color.Info" HideSpinButtons="true" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-lg h-100 pay2-card-green">
                            <div class="d-flex align-center mb-6">
                                <div style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--mud-palette-success);" class="ml-2"></div>
                                <MudText Typo="Typo.subtitle1" Color="Color.Success" Style="font-weight: bold;">بخش اسپری (Spray Dryer Unit)</MudText>
                            </div>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">شروع اسپری:</MudText>
                                    <MudTimePicker @bind-Time="Model.SprayStart" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">پایان اسپری:</MudText>
                                    <MudTimePicker @bind-Time="Model.SprayEnd" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Class="text-muted mb-1 d-block">مقدار پودر خروجی:</MudText>
                                    <MudNumericField @bind-Value="Model.SprayPowderQty" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="مثال: ۱۲۰۰" Adornment="Adornment.End" AdornmentText="کیلوگرم" AdornmentColor="Color.Success" HideSpinButtons="true" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mb-2">
                    <MudItem xs="12" md="8">
                        <MudText Typo="Typo.body2" Style="font-weight: bold;" Class="mb-2 text-muted">توضیحات و گزارش شیفت:</MudText>
                        <MudTextField @bind-Value="Model.Description" Variant="Variant.Outlined" Lines="3" Placeholder="توضیحات مربوط به خاموشی‌ها، ایرادات فنی، شستشوی واحد CIP یا ناخالصی‌ها..." />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.body2" Style="font-weight: bold;" Class="mb-2 text-muted">عدد کنتور نهایی:</MudText>
                        <MudTextField @bind-Value="Model.CounterNumber" Variant="Variant.Outlined" Placeholder="مثال: ۲۴۵۸۹" />
                    </MudItem>
                </MudGrid>

                <div class="d-flex justify-start mt-6">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="rounded-xl px-8 py-2" OnClick="Submit" Disabled="_isProcessing" StartIcon="@Icons.Material.Outlined.Save">
                        @if (_isProcessing)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <span style="font-weight: bold;">ثبت قطعی گزارش</span>
                        }
                    </MudButton>
                </div>
            </MudPaper>
        }
        else if (_activeTab == 2)
        {
            <MudTable Items="@FilteredReports" Dense="true" Hover="true" Elevation="1" Virtualize="true" FixedHeader="true" Height="calc(100vh - 250px)">
                <ToolBarContent>
                    <MudTextField @bind-Value="_searchString" Placeholder="جستجو در شرکت یا توضیحات..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>تاریخ</MudTh>
                    <MudTh>شرکت آب‌پنیر</MudTh>
                    <MudTh>آبپنیر (لیتر)</MudTh>
                    <MudTh>زمان تغلیظ</MudTh>
                    <MudTh>پودر (کیلوگرم)</MudTh>
                    <MudTh>زمان اسپری</MudTh>
                    <MudTh>کنتور</MudTh>
                    <MudTh>راندمان</MudTh>
                    <MudTh>نسبت زمانی</MudTh>
                    <MudTh>توضیحات</MudTh>
                    <MudTh>عملیات</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="تاریخ">@GetShamsiDateString(context.ReportDate)</MudTd>
                    <MudTd DataLabel="شرکت">@context.WheyCompany</MudTd>
                    <MudTd DataLabel="آبپنیر">@context.ConcentrationWheyQty?.ToString("N0")</MudTd>
                    <MudTd DataLabel="زمان تغلیظ">
                        <div><span dir="ltr">@(context.ConcentrationStart?.ToString(@"hh\:mm") ?? "-")</span> تا <span dir="ltr">@(context.ConcentrationEnd?.ToString(@"hh\:mm") ?? "-")</span></div>
                        @{ var concElapsed = GetElapsedTime(context.ConcentrationStart, context.ConcentrationEnd); }
                        @if (concElapsed.HasValue)
                        {
                            <div class="mud-typography-caption" style="color: var(--mud-palette-text-secondary);">مدت: <span dir="ltr">@FormatElapsedTime(concElapsed)</span> ساعت</div>
                        }
                    </MudTd>
                    <MudTd DataLabel="پودر">@context.SprayPowderQty?.ToString("N0")</MudTd>
                    <MudTd DataLabel="زمان اسپری">
                        <div><span dir="ltr">@(context.SprayStart?.ToString(@"hh\:mm") ?? "-")</span> تا <span dir="ltr">@(context.SprayEnd?.ToString(@"hh\:mm") ?? "-")</span></div>
                        @{ var sprayElapsed = GetElapsedTime(context.SprayStart, context.SprayEnd); }
                        @if (sprayElapsed.HasValue)
                        {
                            <div class="mud-typography-caption" style="color: var(--mud-palette-text-secondary);">مدت: <span dir="ltr">@FormatElapsedTime(sprayElapsed)</span> ساعت</div>
                        }
                    </MudTd>
                    <MudTd DataLabel="کنتور">@context.CounterNumber</MudTd>
                    <MudTd DataLabel="راندمان">
                        @{
                            var ratioRow = context.SprayPowderQty > 0 ? ((decimal)(context.ConcentrationWheyQty ?? 0) / (decimal)(context.SprayPowderQty ?? 0)) : 0;
                            var efficiencyRow = context.ConcentrationWheyQty > 0 ? ((decimal)(context.SprayPowderQty ?? 0) / (decimal)(context.ConcentrationWheyQty ?? 0) * 100) : 0;
                        }
                        @if (ratioRow > 0)
                        {
                            <span>@ratioRow.ToString("N1") (@efficiencyRow.ToString("N1")٪)</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="نسبت زمانی">
                        @{
                            var _concE = GetElapsedTime(context.ConcentrationStart, context.ConcentrationEnd);
                            var _sprayE = GetElapsedTime(context.SprayStart, context.SprayEnd);
                            var wheyPerHour = _concE.HasValue && _concE.Value.TotalHours > 0 && context.ConcentrationWheyQty > 0
                                ? context.ConcentrationWheyQty!.Value / (decimal)_concE.Value.TotalHours
                                : (decimal?)null;
                            var powderPerHour = _sprayE.HasValue && _sprayE.Value.TotalHours > 0 && context.SprayPowderQty > 0
                                ? context.SprayPowderQty!.Value / (decimal)_sprayE.Value.TotalHours
                                : (decimal?)null;
                        }
                        @if (wheyPerHour.HasValue)
                        {
                            <div>آب‌پنیر: <span dir="ltr">@wheyPerHour.Value.ToString("N0")</span> ل/ساعت</div>
                        }
                        @if (powderPerHour.HasValue)
                        {
                            <div>پودر: <span dir="ltr">@powderPerHour.Value.ToString("N0")</span> ک/ساعت</div>
                        }
                        @if (!wheyPerHour.HasValue && !powderPerHour.HasValue)
                        {
                            <span>-</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="توضیحات">
                        @if (!string.IsNullOrWhiteSpace(context.Description))
                        {
                            <MudTooltip Text="@context.Description">
                                <div class="text-truncate" style="max-width: 150px;">
                                    @context.Description
                                </div>
                            </MudTooltip>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="عملیات">
                        <div class="d-flex align-center gap-4">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Medium" Color="Color.Info" OnClick="() => EditReport(context)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Medium" Color="Color.Error" OnClick="() => DeleteReport(context)" />
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
</div>

@code {
    private bool _isDataLoaded = false;
    private int _activeTab = 1;
    private bool _isProcessing = false;
    private string _searchString = string.Empty;

    private string? _shamsiDateStr;
    private List<ProductionReportDto> _reports = new();
    private ProductionReportDto Model = new();

    // متغیرهای داشبورد آماری
    private decimal TotalWheyQty => _reports.Sum(x => x.ConcentrationWheyQty ?? 0);
    private decimal TotalPowderQty => _reports.Sum(x => x.SprayPowderQty ?? 0);

    private List<ChartSeries> _chartSeries = new();
    private string[] _chartXLabels = Array.Empty<string>();
    private double[] _donutData = Array.Empty<double>();
    private string[] _donutLabels = new[] { "پودر تولیدی (کیلوگرم)", "آب‌پنیر تبخیر شده (لیتر)" };
    private ChartOptions _chartOptions = new();

    private IEnumerable<ProductionReportDto> FilteredReports =>
        string.IsNullOrWhiteSpace(_searchString)
            ? _reports
            : _reports.Where(x =>
                (x.WheyCompany != null && x.WheyCompany.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                (x.Description != null && x.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        _shamsiDateStr = GetTodayShamsi();
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _reports = await ApiService.GetReportsAsync();
            CalculateDashboardStats(); // متد آمار بعد از دریافت داده‌ها
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطا در دریافت اطلاعات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDataLoaded = true;
        }
    }

    private void CalculateDashboardStats()
    {
        if (_reports == null || !_reports.Any()) return;

        var topReports = _reports.OrderBy(x => x.ReportDate).TakeLast(5).ToList();
        _chartXLabels = topReports.Select(x => GetShamsiDateStringShort(x.ReportDate)).ToArray();

        _chartSeries = new List<ChartSeries>
        {
            new() { Name = "آبپنیر دریافتی (لیتر)", Data = topReports.Select(x => (double)(x.ConcentrationWheyQty ?? 0)).ToArray() },
            new() { Name = "پودر خروجی (کیلوگرم)", Data = topReports.Select(x => (double)(x.SprayPowderQty ?? 0)).ToArray() }
        };

        if (TotalWheyQty > 0)
        {
            double remainingLiquid = (double)TotalWheyQty - (double)TotalPowderQty;
            _donutData = new double[] { (double)TotalPowderQty, remainingLiquid > 0 ? remainingLiquid : 0 };
            _donutLabels = new[]
            {
                $"پودر تولیدی ({TotalPowderQty.ToString("N0")} کیلوگرم)",
                $"آب‌پنیر تبخیر شده ({(remainingLiquid > 0 ? remainingLiquid : 0).ToString("N0")} لیتر)"
            };
        }
    }

    private TimeSpan? GetElapsedTime(TimeSpan? start, TimeSpan? end)
    {
        if (!start.HasValue || !end.HasValue) return null;
        var elapsed = end.Value - start.Value;
        if (elapsed < TimeSpan.Zero)
            elapsed = elapsed.Add(TimeSpan.FromHours(24));
        return elapsed;
    }

    private string FormatElapsedTime(TimeSpan? elapsed)
    {
        if (!elapsed.HasValue) return "-";
        int hours = (int)elapsed.Value.TotalHours;
        int minutes = elapsed.Value.Minutes;
        return $"{hours}:{minutes:00}";
    }

    private string GetShamsiDateString(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new System.Globalization.PersianCalendar();
        return $"{pc.GetYear(date.Value):0000}/{pc.GetMonth(date.Value):00}/{pc.GetDayOfMonth(date.Value):00}";
    }

    private string GetShamsiDateStringShort(DateTime? date)
    {
        if (!date.HasValue) return "";
        var pc = new System.Globalization.PersianCalendar();
        return $"{pc.GetMonth(date.Value):00}/{pc.GetDayOfMonth(date.Value):00}";
    }

    private string GetTodayShamsi()
    {
        var pc = new System.Globalization.PersianCalendar();
        var now = DateTime.Now;
        return $"{pc.GetYear(now):0000}{pc.GetMonth(now):00}{pc.GetDayOfMonth(now):00}";
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(Model.WheyCompany) || string.IsNullOrWhiteSpace(_shamsiDateStr))
        {
            Snackbar.Add("تکمیل فیلدهای تاریخ و شرکت اجباری است.", Severity.Warning);
            return;
        }

        try
        {
            _isProcessing = true;

            // تبدیل تاریخ شمسی ورودی (به فرمت yyyyMMdd یا مشابه) به میلادی
            DateTime parsedDate = DateTime.Now;
            var cleanShamsi = Safir.Shared.Utility.CL_METHODS.FixPersianChars((_shamsiDateStr ?? "").Replace("/", "").Replace("-", ""));
            if (cleanShamsi.Length == 8 && int.TryParse(cleanShamsi.Substring(0, 4), out int year) &&
                int.TryParse(cleanShamsi.Substring(4, 2), out int month) &&
                int.TryParse(cleanShamsi.Substring(6, 2), out int day))
            {
                var pc = new System.Globalization.PersianCalendar();
                try
                {
                    parsedDate = pc.ToDateTime(year, month, day, 0, 0, 0, 0);
                }
                catch
                {
                    // اگر تاریخ نامعتبر بود، از همان تاریخ فعلی استفاده کن
                }
            }
            Model.ReportDate = parsedDate;

            await ApiService.SaveReportAsync(Model);
            Snackbar.Add("گزارش با موفقیت ثبت شد.", Severity.Success);

            Model = new ProductionReportDto();
            _shamsiDateStr = GetTodayShamsi();

            await LoadData();
            _activeTab = 2;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطا در ثبت گزارش: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void EditReport(ProductionReportDto report)
    {
        Model = new ProductionReportDto
        {
            Id = report.Id,
            ReportDate = report.ReportDate,
            WheyCompany = report.WheyCompany,
            ConcentrationStart = report.ConcentrationStart,
            ConcentrationEnd = report.ConcentrationEnd,
            ConcentrationWheyQty = report.ConcentrationWheyQty,
            SprayStart = report.SprayStart,
            SprayEnd = report.SprayEnd,
            SprayPowderQty = report.SprayPowderQty,
            CounterNumber = report.CounterNumber,
            Description = report.Description
        };

        // بازیابی تاریخ شمسی برای زمان ویرایش
        if (report.ReportDate.HasValue)
        {
            var pc = new System.Globalization.PersianCalendar();
            _shamsiDateStr = $"{pc.GetYear(report.ReportDate.Value):0000}{pc.GetMonth(report.ReportDate.Value):00}{pc.GetDayOfMonth(report.ReportDate.Value):00}";
        }
        else
        {
            _shamsiDateStr = "";
        }
        _activeTab = 1;
    }

    private async Task DeleteReport(ProductionReportDto report)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "تایید حذف",
            $"آیا از حذف گزارش تولید روز {report.ReportDate?.ToString("yyyy/MM/dd")} اطمینان دارید؟",
            yesText: "بله، حذف شود", cancelText: "انصراف");

        if (confirm == true)
        {
            try
            {
                await ApiService.DeleteReportAsync(report.Id);
                Snackbar.Add("گزارش با موفقیت حذف شد.", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"خطا در حذف گزارش: {ex.Message}", Severity.Error);
            }
        }
    }
