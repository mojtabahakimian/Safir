@using Safir.Shared.Models.Salary
@inject Pay2WorkshopApiService WorkshopApi
@using Safir.Shared.Models
@inject LookupApiService LookupService

<div class="pay2-tab-container">
    <div class="pay2-workshop-layout">

        @* ══════════════════════════════════════════
           پنل چپ: لیست کارگاه‌ها
           ══════════════════════════════════════════ *@
        <div class="pay2-workshop-list">

            <div class="pay2-card-header">
                <h5>لیست کارگاه‌ها</h5>
                <button class="btn-outline-pay2" @onclick="NewWorkshop">
                    <i class="bi bi-plus-lg"></i> جدید
                </button>
            </div>

            @if (IsLoadingWorkshops)
            {
                <div class="p2-loading">
                    <div class="p2-spinner"></div>
                    در حال بارگذاری...
                </div>
            }
            else if (!Workshops.Any())
            {
                <div class="p2-empty-state">
                    <i class="bi bi-building"></i>
                    <h4>کارگاهی ثبت نشده</h4>
                    <p>برای شروع، دکمه «جدید» را بزنید.</p>
                </div>
            }
            else
            {
                <table class="workshop-table">
                    <thead>
                        <tr>
                            <th>کد</th>
                            <th>نام کارگاه</th>
                            <th>نوع بیمه</th>
                            <th>وضعیت</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Workshops)
                        {
                            <tr class="workshop-row @(CurrentWorkshop.WS_ID == item.WS_ID ? "active" : "")"
                                @onclick="() => SelectWorkshop(item)">
                                <td class="p2-text-mono">@item.WS_CODE</td>
                                <td>@item.WS_NAME</td>
                                <td class="p2-text-muted" style="font-size:12px;">@item.InsModeText</td>
                                <td>
                                    @if (item.IS_ACTIVE)
                                    {
                                        <span class="p2-badge-success">فعال</span>
                                    }
                                    else
                                    {
                                        <span class="p2-badge-neutral">غیرفعال</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        @* ══════════════════════════════════════════
           پنل راست: فرم اطلاعات کارگاه
           ══════════════════════════════════════════ *@
        <div class="card-custom pay2-workshop-form">

            <div class="pay2-card-header">
                <h5>
                    @if (CurrentWorkshop.WS_ID == 0)
                    {
                        <span>کارگاه جدید</span>
                    }
                    else
                    {
                        <span>ویرایش: @CurrentWorkshop.WS_NAME</span>
                    }
                </h5>

                @if (CurrentWorkshop.WS_ID != 0)
                {
                    <span class="p2-badge-primary">WS_ID: @CurrentWorkshop.WS_ID</span>
                }
            </div>

            @* ─── بخش ۱: اطلاعات پایه ─── *@
            <div class="p2-sub-card-title">
                <i class="bi bi-info-circle"></i> اطلاعات پایه
            </div>

            <div class="form-grid-2">

                <div class="form-field">
                    <label>کد کارگاه *</label>

                    <Pay2NumericInput @bind-Value="CurrentWorkshop.WS_CODE"
                                      MaxLength="10"
                                      Placeholder="مثال: 1050"
                                      CssClass="@(HasError(nameof(CurrentWorkshop.WS_CODE)) ? "error" : "")"
                                      OnFocus="@(_ => ClearError(nameof(CurrentWorkshop.WS_CODE)))"
                                      OnBlur="@(_ => NormalizeWorkshopCode())" />

                    @if (HasError(nameof(CurrentWorkshop.WS_CODE)))
                    {
                        <span class="field-error">@GetError(nameof(CurrentWorkshop.WS_CODE))</span>
                    }
                </div>

                <div class="form-field">
                    <label>نام کارگاه *</label>

                    <input class="pay2-input @(HasError(nameof(CurrentWorkshop.WS_NAME)) ? "error" : "")"
                           type="text"
                           maxlength="100"
                           placeholder="مثال: کارگاه مرکزی"
                           @bind-value="CurrentWorkshop.WS_NAME"
                           @bind-value:event="onchange"
                           @onfocus="() => ClearError(nameof(CurrentWorkshop.WS_NAME))" />

                    @if (HasError(nameof(CurrentWorkshop.WS_NAME)))
                    {
                        <span class="field-error">@GetError(nameof(CurrentWorkshop.WS_NAME))</span>
                    }
                </div>

                <div class="form-field">
                    <label>کد کارگاه بیمه</label>

                    <Pay2NumericInput @bind-Value="CurrentWorkshop.SOCIAL_INS_CODE"
                                      MaxLength="20"
                                      Placeholder="کد تأمین اجتماعی" />
                </div>

                <div class="form-field">
                    <label>شناسه مالیاتی</label>

                    <input class="pay2-input"
                           type="text"
                           maxlength="20"
                           placeholder="شناسه مالیاتی"
                           @bind-value="CurrentWorkshop.TAX_CODE"
                           @bind-value:event="onchange" />
                </div>

                <div class="form-field">
                    <label>شناسه ملی</label>

                    <Pay2NumericInput @bind-Value="CurrentWorkshop.NATIONAL_ID"
                                      MaxLength="11"
                                      Placeholder="۱۱ رقم"
                                      CssClass="@(HasError(nameof(CurrentWorkshop.NATIONAL_ID)) ? "error" : "")"
                                      OnFocus="@(_ => ClearError(nameof(CurrentWorkshop.NATIONAL_ID)))"
                                      OnBlur="@(_ => ValidateNationalId())" />

                    @if (HasError(nameof(CurrentWorkshop.NATIONAL_ID)))
                    {
                        <span class="field-error">@GetError(nameof(CurrentWorkshop.NATIONAL_ID))</span>
                    }
                </div>

                <div class="form-field">
                    <label>تلفن</label>

                    <Pay2NumericInput @bind-Value="CurrentWorkshop.PHONE"
                                      MaxLength="20"
                                      Placeholder="شماره تماس" />
                </div>

            </div>

            <div class="form-field p2-mt-8">
                <label>آدرس</label>

                <input class="pay2-input"
                       type="text"
                       maxlength="300"
                       placeholder="آدرس کامل کارگاه"
                       @bind-value="CurrentWorkshop.ADDRESS"
                       @bind-value:event="onchange" />
            </div>

            @* ─── ردیف وضعیت + نوع بیمه ─── *@
            <div class="form-grid-2 p2-mt-8">

                <div class="form-field">
                    <label>وضعیت کارگاه</label>

                    <div class="pay2-wpf-checkbox-box">
                        <label class="pay2-wpf-checkbox-label">
                            <input type="checkbox" @bind="CurrentWorkshop.IS_ACTIVE" />
                            کارگاه فعال است
                        </label>
                    </div>
                </div>

                <div class="form-field">
                    <label>نوع محاسبه بیمه</label>

                    <Pay2Select TItem="Pay2InsModeOption"
                                TValue="int"
                                Items="InsModeOptions"
                                @bind-Value="CurrentWorkshop.INS_MODE"
                                TextSelector="@(x => x.Title)"
                                ValueSelector="@(x => x.Id)"
                                SubTextSelector="@(x => x.Description)"
                                Placeholder="انتخاب نوع بیمه"
                                Editable="true"
                                Clearable="false"
                                MaxVisibleItems="20" />
                </div>

            </div>

            @* ─── بخش ۲: سرفصل‌های حسابداری ─── *@
            <hr class="p2-divider" />

            <div class="p2-sub-card-title">
                <i class="bi bi-journal-bookmark"></i> سرفصل‌های حسابداری
            </div>

            <div class="form-grid-2">

                <div class="form-field" style="grid-column: span 2;">
                    <label>
                        حساب مساعده هوشمند
                        <span class="p2-text-muted" style="font-size:11px; font-weight:400;">
                            (جستجو بر اساس نام یا کد حساب)
                        </span>
                    </label>

                    <Pay2Select TItem="LookupDto<string>"
                                TValue="string"
                                SearchItems="SearchAccountsAsync"
                                Items="InitialAdvHesList"
                                Value="CurrentWorkshopAcc.ADV_HES"
                                ValueChanged="OnAdvHesChanged"
                                TextSelector="@(x => $"{x.Name}  |  {x.Id}")"
                                ValueSelector="@(x => x.Id)"
                                Placeholder="جستجوی حساب (مثال: 213-1-16 یا نام حساب)"
                                CssClass="@(HasError(nameof(CurrentWorkshopAcc.ADV_HES)) ? "error" : "")"
                                Clearable="true"
                                Editable="true"
                                MaxVisibleItems="50"
                                DebounceMilliseconds="400"
                                ClearValueOnTextEdit="true" />

                    @if (HasError(nameof(CurrentWorkshopAcc.ADV_HES)))
                    {
                        <span class="field-error">@GetError(nameof(CurrentWorkshopAcc.ADV_HES))</span>
                    }
                </div>

                <div class="form-field">
                    <label>هزینه حقوق</label>

                    <input class="pay2-input"
                           type="text"
                           maxlength="20"
                           placeholder="SALARY_EXP"
                           @bind-value="CurrentWorkshopAcc.SALARY_EXP"
                           @bind-value:event="onchange" />
                </div>

                <div class="form-field">
                    <label>پرداختنی حقوق</label>

                    <input class="pay2-input"
                           type="text"
                           maxlength="20"
                           placeholder="SALARY_PAYABLE"
                           @bind-value="CurrentWorkshopAcc.SALARY_PAYABLE"
                           @bind-value:event="onchange" />
                </div>

                <div class="form-field">
                    <label>هزینه بیمه</label>

                    <input class="pay2-input"
                           type="text"
                           maxlength="20"
                           placeholder="INS_EXP"
                           @bind-value="CurrentWorkshopAcc.INS_EXP"
                           @bind-value:event="onchange" />
                </div>

                <div class="form-field">
                    <label>پرداختنی بیمه</label>

                    <input class="pay2-input"
                           type="text"
                           maxlength="20"
                           placeholder="INS_PAYABLE"
                           @bind-value="CurrentWorkshopAcc.INS_PAYABLE"
                           @bind-value:event="onchange" />
                </div>

                <div class="form-field">
                    <label>پرداختنی مالیات</label>

                    <input class="pay2-input"
                           type="text"
                           maxlength="20"
                           placeholder="TAX_PAYABLE"
                           @bind-value="CurrentWorkshopAcc.TAX_PAYABLE"
                           @bind-value:event="onchange" />
                </div>

            </div>

            @* ─── دکمه‌های عملیات ─── *@
            <div style="display:flex; gap:10px; margin-top:28px; flex-wrap:wrap;">
                <button class="btn-primary-pay2"
                        @onclick="SaveWorkshopAsync"
                        disabled="@IsSavingWorkshop">
                    @if (IsSavingWorkshop)
                    {
                        <span class="p2-spinner" style="width:14px;height:14px;border-width:2px;"></span>
                        <span>در حال ذخیره...</span>
                    }
                    else
                    {
                        <i class="bi bi-floppy"></i>
                        <span>ذخیره اطلاعات کارگاه</span>
                    }
                </button>

                <button class="btn-outline-pay2"
                        @onclick="NewWorkshop"
                        disabled="@IsSavingWorkshop">
                    <i class="bi bi-x-lg"></i> انصراف / جدید
                </button>
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnToast { get; set; }

    private List<Pay2WorkshopDto> Workshops = new();
    private Pay2WorkshopDto CurrentWorkshop = new();
    private Pay2WorkshopAccDto CurrentWorkshopAcc = new();

    private bool IsLoadingWorkshops;
    private bool IsSavingWorkshop;
    private bool IsInsModeDropdownOpen;

    private readonly Dictionary<string, string> _fieldErrors = new();

    protected override async Task OnInitializedAsync()
    {
        NewWorkshop();
        await LoadWorkshopsAsync();
    }

    private async Task LoadWorkshopsAsync()
    {
        IsLoadingWorkshops = true;

        try
        {
            Workshops = await WorkshopApi.GetWorkshopsAsync();
        }
        catch (Exception ex)
        {
            await Toast("خطا در واکشی لیست کارگاه‌ها: " + ex.Message);
        }
        finally
        {
            IsLoadingWorkshops = false;
        }
    }
    private static readonly List<Pay2InsModeOption> InsModeOptions = new()
    {
        new Pay2InsModeOption
        {
            Id = 1,
            Title = "معمولی",
            Description = "کارگاه معمولی"
        },
        new Pay2InsModeOption
        {
            Id = 2,
            Title = "ده‌درصدی",
            Description = "تبصره ماده ۷ / SANAD10"
        }
    };
    private sealed class Pay2InsModeOption
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string? Description { get; set; }
    }

    private async Task SelectWorkshop(Pay2WorkshopDto selected)
    {
        CurrentWorkshop = new Pay2WorkshopDto
        {
            WS_ID = selected.WS_ID,
            WS_CODE = OnlyDigits(selected.WS_CODE, 10),
            WS_NAME = CleanText(selected.WS_NAME),
            NATIONAL_ID = OnlyDigits(selected.NATIONAL_ID, 11),
            SOCIAL_INS_CODE = OnlyDigits(selected.SOCIAL_INS_CODE, 20),
            TAX_CODE = CleanText(selected.TAX_CODE),
            ADDRESS = CleanText(selected.ADDRESS),
            PHONE = OnlyDigits(selected.PHONE, 20),
            IS_ACTIVE = selected.IS_ACTIVE,
            INS_MODE = NormalizeInsMode(selected.INS_MODE)
        };

        _fieldErrors.Clear();
        IsInsModeDropdownOpen = false;

        try
        {
            CurrentWorkshopAcc = await WorkshopApi.GetAccountsAsync(selected.WS_ID);
            NormalizeAccounts();

            InitialAdvHesList.Clear();
            if (!string.IsNullOrWhiteSpace(CurrentWorkshopAcc.ADV_HES))
            {
                var lookupResult = await LookupService.GetCustomerLookupAsync(CurrentWorkshopAcc.ADV_HES);
                var matchedItem = lookupResult?.FirstOrDefault(x => x.Id == CurrentWorkshopAcc.ADV_HES);
                if (matchedItem != null)
                {
                    InitialAdvHesList.Add(matchedItem);
                }
                else
                {
                    InitialAdvHesList.Add(new LookupDto<string>(CurrentWorkshopAcc.ADV_HES, "حساب نامشخص"));
                }
            }
        }
        catch (Exception ex)
        {
            CurrentWorkshopAcc = new Pay2WorkshopAccDto { WS_ID = selected.WS_ID };
            InitialAdvHesList.Clear();

            await Toast("خطا در واکشی سرفصل‌های حسابداری: " + ex.Message);
        }
    }

    private void NewWorkshop()
    {
        CurrentWorkshop = new Pay2WorkshopDto
        {
            IS_ACTIVE = true,
            INS_MODE = 1
        };

        CurrentWorkshopAcc = new Pay2WorkshopAccDto();
        InitialAdvHesList.Clear();

        _fieldErrors.Clear();
        IsInsModeDropdownOpen = false;
    }
    private async Task SaveWorkshopAsync()
    {
        IsInsModeDropdownOpen = false;

        NormalizeWorkshop();
        NormalizeAccounts();

        _fieldErrors.Clear();

        if (string.IsNullOrWhiteSpace(CurrentWorkshop.WS_CODE))
        {
            _fieldErrors[nameof(CurrentWorkshop.WS_CODE)] = "کد کارگاه نمی‌تواند خالی باشد.";
        }

        if (string.IsNullOrWhiteSpace(CurrentWorkshop.WS_NAME))
        {
            _fieldErrors[nameof(CurrentWorkshop.WS_NAME)] = "نام کارگاه نمی‌تواند خالی باشد.";
        }

        if (!string.IsNullOrWhiteSpace(CurrentWorkshop.NATIONAL_ID) &&
            CurrentWorkshop.NATIONAL_ID.Length != 11)
        {
            _fieldErrors[nameof(CurrentWorkshop.NATIONAL_ID)] = "شناسه ملی باید دقیقاً ۱۱ رقم باشد.";
        }

        ValidateAdvHes();

        if (_fieldErrors.Any())
        {
            await Toast(_fieldErrors.First().Value);
            return;
        }

        IsSavingWorkshop = true;

        try
        {
            var request = new Pay2WorkshopSaveRequest
            {
                Workshop = CurrentWorkshop,
                Accounts = CurrentWorkshopAcc
            };

            var savedId = await WorkshopApi.SaveAsync(request);

            await LoadWorkshopsAsync();

            var saved = Workshops.FirstOrDefault(x => x.WS_ID == savedId);
            if (saved != null)
            {
                await SelectWorkshop(saved);
            }

            await Toast("اطلاعات کارگاه با موفقیت ذخیره شد.");
        }
        catch (Exception ex)
        {
            await Toast("خطا: " + ex.Message);
        }
        finally
        {
            IsSavingWorkshop = false;
        }
    }

    private void NormalizeWorkshopCode()
    {
        CurrentWorkshop.WS_CODE = OnlyDigits(CurrentWorkshop.WS_CODE, 10);
    }

    #region MosaedehCode
    // لیست اولیه فقط برای نمایش نام حسابی که از دیتابیس لود می‌شود (جلوگیری از خالی ماندن تکست‌باکس در حالت ویرایش)
    private List<LookupDto<string>> InitialAdvHesList = new();

    // متد جستجوی سمت سرور برای AutoComplete (بدون Memory Leak)
    private async Task<IEnumerable<LookupDto<string>>> SearchAccountsAsync(string? searchTerm)
    {
        var result = await LookupService.GetCustomerLookupAsync(searchTerm);
        return result ?? Enumerable.Empty<LookupDto<string>>();
    }

    // رویداد تغییر مقدار حساب
    private void OnAdvHesChanged(string? newValue)
    {
        CurrentWorkshopAcc.ADV_HES = newValue;
        ValidateAdvHes();
    }
    #endregion

    private void ValidateNationalId()
    {
        CurrentWorkshop.NATIONAL_ID = OnlyDigits(CurrentWorkshop.NATIONAL_ID, 11);

        var value = CurrentWorkshop.NATIONAL_ID;

        if (!string.IsNullOrWhiteSpace(value) && value.Length != 11)
        {
            _fieldErrors[nameof(CurrentWorkshop.NATIONAL_ID)] = "شناسه ملی باید دقیقاً ۱۱ رقم باشد.";
        }
        else
        {
            _fieldErrors.Remove(nameof(CurrentWorkshop.NATIONAL_ID));
        }
    }

    private void ValidateAdvHes()
    {
        CurrentWorkshopAcc.ADV_HES = CleanAccount(CurrentWorkshopAcc.ADV_HES, 20);

        var value = CurrentWorkshopAcc.ADV_HES;

        if (string.IsNullOrWhiteSpace(value))
        {
            _fieldErrors.Remove(nameof(CurrentWorkshopAcc.ADV_HES));
            return;
        }

        var parts = value.Split('-', StringSplitOptions.RemoveEmptyEntries);

        var valid = parts.Length >= 2
                    && parts.All(part => part.All(char.IsDigit))
                    && !value.StartsWith("-")
                    && !value.EndsWith("-")
                    && !value.Contains("--");

        if (!valid)
        {
            _fieldErrors[nameof(CurrentWorkshopAcc.ADV_HES)] =
                "فرمت نادرست. حداقل دو عدد با خط‌فاصله وارد کنید. مثال: 112-1 یا 213-1-5";
        }
        else
        {
            _fieldErrors.Remove(nameof(CurrentWorkshopAcc.ADV_HES));
        }
    }

    private void ToggleInsModeDropdown()
    {
        IsInsModeDropdownOpen = !IsInsModeDropdownOpen;
    }

    private void CloseInsModeDropdown()
    {
        IsInsModeDropdownOpen = false;
    }

    private void SelectInsMode(int value)
    {
        CurrentWorkshop.INS_MODE = NormalizeInsMode(value);
        IsInsModeDropdownOpen = false;
    }

    private static int NormalizeInsMode(int value)
    {
        return value == 2 ? 2 : 1;
    }

    private static string GetInsModeText(int value)
    {
        return value switch
        {
            1 => "معمولی",
            2 => "ده‌درصدی",
            _ => "معمولی"
        };
    }

    private bool HasError(string field)
    {
        return _fieldErrors.ContainsKey(field);
    }

    private string GetError(string field)
    {
        return _fieldErrors.TryGetValue(field, out var message) ? message : "";
    }

    private void ClearError(string field)
    {
        _fieldErrors.Remove(field);
    }

    private async Task Toast(string message)
    {
        if (OnToast.HasDelegate)
        {
            await OnToast.InvokeAsync(message);
        }
    }

    private void NormalizeWorkshop()
    {
        CurrentWorkshop.WS_CODE = OnlyDigits(CurrentWorkshop.WS_CODE, 10);
        CurrentWorkshop.WS_NAME = CleanText(CurrentWorkshop.WS_NAME);
        CurrentWorkshop.NATIONAL_ID = OnlyDigits(CurrentWorkshop.NATIONAL_ID, 11);
        CurrentWorkshop.SOCIAL_INS_CODE = OnlyDigits(CurrentWorkshop.SOCIAL_INS_CODE, 20);
        CurrentWorkshop.TAX_CODE = CleanText(CurrentWorkshop.TAX_CODE);
        CurrentWorkshop.ADDRESS = CleanText(CurrentWorkshop.ADDRESS);
        CurrentWorkshop.PHONE = OnlyDigits(CurrentWorkshop.PHONE, 20);
        CurrentWorkshop.INS_MODE = NormalizeInsMode(CurrentWorkshop.INS_MODE);
    }

    private void NormalizeAccounts()
    {
        CurrentWorkshopAcc.ADV_HES = CleanAccount(CurrentWorkshopAcc.ADV_HES, 20);
        CurrentWorkshopAcc.SALARY_EXP = CleanText(CurrentWorkshopAcc.SALARY_EXP);
        CurrentWorkshopAcc.SALARY_PAYABLE = CleanText(CurrentWorkshopAcc.SALARY_PAYABLE);
        CurrentWorkshopAcc.INS_EXP = CleanText(CurrentWorkshopAcc.INS_EXP);
        CurrentWorkshopAcc.INS_PAYABLE = CleanText(CurrentWorkshopAcc.INS_PAYABLE);
        CurrentWorkshopAcc.TAX_PAYABLE = CleanText(CurrentWorkshopAcc.TAX_PAYABLE);
    }

    private static string? OnlyDigits(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var result = new List<char>();

        foreach (var ch in value)
        {
            if (ch >= '0' && ch <= '9')
            {
                result.Add(ch);
            }
            else if (ch >= '۰' && ch <= '۹')
            {
                result.Add((char)('0' + (ch - '۰')));
            }
            else if (ch >= '٠' && ch <= '٩')
            {
                result.Add((char)('0' + (ch - '٠')));
            }

            if (maxLength > 0 && result.Count >= maxLength)
            {
                break;
            }
        }

        var text = new string(result.ToArray());
        return string.IsNullOrWhiteSpace(text) ? null : text;
    }

    private static string? CleanAccount(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var result = new List<char>();

        foreach (var ch in value.Trim())
        {
            if (ch >= '0' && ch <= '9')
            {
                result.Add(ch);
            }
            else if (ch >= '۰' && ch <= '۹')
            {
                result.Add((char)('0' + (ch - '۰')));
            }
            else if (ch >= '٠' && ch <= '٩')
            {
                result.Add((char)('0' + (ch - '٠')));
            }
            else if (ch == '-')
            {
                result.Add('-');
            }

            if (maxLength > 0 && result.Count >= maxLength)
            {
                break;
            }
        }

        var text = new string(result.ToArray());
        return string.IsNullOrWhiteSpace(text) ? null : text;
    }

    private static string? CleanText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }
}