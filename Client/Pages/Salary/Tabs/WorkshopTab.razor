    }

    static int NormalizeInsMode(int value)
    {
        return value == 2 ? 2 : 1;
    }

    static string GetInsModeText(int value)
    {
        return value switch
        {
            1 => "معمولی",
            2 => "ده‌درصدی",
            _ => "معمولی"
        };
    }

    bool HasError(string field)
    {
        return _fieldErrors.ContainsKey(field);
    }

    string GetError(string field)
    {
        return _fieldErrors.TryGetValue(field, out var message) ? message : "";
    }

    void ClearError(string field)
    {
        _fieldErrors.Remove(field);
    }

    async Task Toast(string message)
    {
        if (OnToast.HasDelegate)
        {
            await OnToast.InvokeAsync(message);
        }
    }

    void NormalizeWorkshop()
    {
        CurrentWorkshop.WS_CODE = OnlyDigits(CurrentWorkshop.WS_CODE, 10);
        CurrentWorkshop.WS_NAME = CleanText(CurrentWorkshop.WS_NAME);
        CurrentWorkshop.NATIONAL_ID = OnlyDigits(CurrentWorkshop.NATIONAL_ID, 11);
        CurrentWorkshop.SOCIAL_INS_CODE = OnlyDigits(CurrentWorkshop.SOCIAL_INS_CODE, 20);
        CurrentWorkshop.TAX_CODE = CleanText(CurrentWorkshop.TAX_CODE);
        CurrentWorkshop.ADDRESS = CleanText(CurrentWorkshop.ADDRESS);
        CurrentWorkshop.PHONE = OnlyDigits(CurrentWorkshop.PHONE, 20);
        CurrentWorkshop.INS_MODE = NormalizeInsMode(CurrentWorkshop.INS_MODE);
    }

    void NormalizeAccounts()
    {
        CurrentWorkshopAcc ??= new Pay2WorkshopAccDto();

        CurrentWorkshopAcc.ADV_HES = CleanAccount(CurrentWorkshopAcc.ADV_HES, 20);
        CurrentWorkshopAcc.SALARY_EXP_TOLID = CleanAccount(CurrentWorkshopAcc.SALARY_EXP_TOLID, 20);
        CurrentWorkshopAcc.SALARY_EXP_EDARI = CleanAccount(CurrentWorkshopAcc.SALARY_EXP_EDARI, 20);
        CurrentWorkshopAcc.SALARY_EXP_FOROSH = CleanAccount(CurrentWorkshopAcc.SALARY_EXP_FOROSH, 20);
        CurrentWorkshopAcc.SALARY_EXP_KHADAMAT = CleanAccount(CurrentWorkshopAcc.SALARY_EXP_KHADAMAT, 20);
        CurrentWorkshopAcc.SALARY_PAYABLE = CleanAccount(CurrentWorkshopAcc.SALARY_PAYABLE, 20);
        CurrentWorkshopAcc.LOAN_HES = CleanAccount(CurrentWorkshopAcc.LOAN_HES, 20);
        CurrentWorkshopAcc.INS_EXP = CleanAccount(CurrentWorkshopAcc.INS_EXP, 20);
        CurrentWorkshopAcc.INS_PAYABLE = CleanAccount(CurrentWorkshopAcc.INS_PAYABLE, 20);
        CurrentWorkshopAcc.TAX_PAYABLE = CleanAccount(CurrentWorkshopAcc.TAX_PAYABLE, 20);
        CurrentWorkshopAcc.BANK_PAY_HES = CleanAccount(CurrentWorkshopAcc.BANK_PAY_HES, 20);
    }

    static string? OnlyDigits(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var result = new List<char>();

        foreach (var ch in value)
        {
            if (ch >= '0' && ch <= '9')
            {
                result.Add(ch);
            }
            else if (ch >= '۰' && ch <= '۹')
            {
                result.Add((char)('0' + (ch - '۰')));
            }
            else if (ch >= '٠' && ch <= '٩')
            {
                result.Add((char)('0' + (ch - '٠')));
            }

            if (maxLength > 0 && result.Count >= maxLength)
            {
                break;
            }
        }

        var text = new string(result.ToArray());
        return string.IsNullOrWhiteSpace(text) ? null : text;
    }

    static string? CleanAccount(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var result = new List<char>();

        foreach (var ch in value.Trim())
        {
            if (ch >= '0' && ch <= '9')
            {
                result.Add(ch);
            }
            else if (ch >= '۰' && ch <= '۹')
            {
                result.Add((char)('0' + (ch - '۰')));
            }
            else if (ch >= '٠' && ch <= '٩')
            {
                result.Add((char)('0' + (ch - '٠')));
            }
            else if (ch == '-')
            {
                result.Add('-');
            }

            if (maxLength > 0 && result.Count >= maxLength)
            {
                break;
            }
        }

        var text = new string(result.ToArray());
        return string.IsNullOrWhiteSpace(text) ? null : text;
    }

    static string? CleanText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    void CancelSelectWorkshop()
    {
        var cts = _selectWorkshopCts;
        _selectWorkshopCts = null;

        if (cts == null)
            return;

        try { cts.Cancel(); } catch { }
        try { cts.Dispose(); } catch { }
    }

    public void Dispose()
    {
        CancelSelectWorkshop();
    }
