@inject Pay2EmployeeApiService EmployeeApi
@inject Pay2WorkshopApiService WorkshopApi
@inject LookupApiService LookupService
@inject ISnackbar Snackbar
@using Safir.Shared.Models.Salary
@using Safir.Shared.Models

<div class="pay2-tab-container">
    <div class="pay2-card-header">
        <div>
            <h5 class="pay2-section-title">مدیریت پرسنل (PAY2_EMPLOYEE)</h5>
            <div class="pay2-section-subtitle">لیست پرسنل، اطلاعات پایه و ارتباط با حسابداری.</div>
        </div>
        <button class="btn-primary-pay2" @onclick="OpenNewEmpModal">
            <i class="bi bi-plus-lg"></i> پرسنل جدید
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="p2-loading"><div class="p2-spinner"></div> در حال دریافت اطلاعات...</div>
    }
    else
    {
        <div class="card-custom" style="padding: 0; overflow:hidden;">
            <!-- اضافه کردن اسکرول عمودی (max-height) و افقی (overflow-x) -->
            <div style="max-height: 65vh; overflow-y: auto; overflow-x: auto; width: 100%;">

                <!-- تنظیم عرض حداقل (min-width: 800px) برای جلوگیری از له شدن ستون‌ها در موبایل -->
                <table class="p2-table" style="position: relative; width: 100%; min-width: 800px;">
                    <thead style="position: sticky; top: 0; z-index: 10;">
                        <tr>
                            <th>کد</th>
                            <th>نام و نام خانوادگی</th>
                            <th>کارگاه</th>
                            <th>شغل</th>
                            <th>کد تفصیلی (مساعده)</th>
                            <th>وضعیت</th>
                            <th style="text-align:center;">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        <Virtualize Items="Employees" Context="emp">
                            <tr>
                                <td class="p2-text-mono p2-text-muted">@emp.EMP_CODE</td>
                                <td><strong>@emp.FIRST_NAME @emp.LAST_NAME</strong><br /><span style="font-size:10px; color:#94a3b8">@emp.NATIONAL_CODE</span></td>
                                <td class="p2-text-muted">@emp.WorkshopName</td>
                                <td class="p2-text-muted">@emp.JobName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(emp.ACC_T))
                                    {
                                        <span class="p2-badge-primary p2-text-mono">@emp.ACC_T</span>
                                    }
                                </td>
                                <td><span class="@(emp.IS_ACTIVE ? "p2-badge-success" : "p2-badge-neutral")">@emp.StatusText</span></td>
                                <td style="text-align:center;">
                                    <button class="btn-ghost-pay2 p2-text-primary" @onclick="() => OpenEditEmpModal(emp)"><i class="bi bi-pencil"></i> ویرایش</button>
                                    <button class="btn-ghost-pay2" style="color:#8b5cf6;" @onclick="() => OpenDecreeModal(emp)"><i class="bi bi-file-earmark-person"></i> احکام</button>
                                </td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>

            </div>
        </div>
    }

    @* ------------------- Modal پرسنل ------------------- *@
    @if (ShowEmpModal)
    {
        <div class="pay2-select-backdrop" style="background: rgba(15,23,42,0.6);" @onclick="CloseModals"></div>
        <div class="card-custom" style="position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); width:900px; max-height:90vh; z-index:3000; overflow-y:auto; padding:0;">
            <div class="p2-card-header" style="padding: 20px; border-bottom: 1px solid var(--p2-border-light); margin:0;">
                <h5 style="margin:0; font-size:18px;">ثبت / ویرایش پرسنل</h5>
                <button class="btn-ghost-pay2" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
            </div>

            <div style="padding: 24px;">
                <div class="p2-sub-card-title"><i class="bi bi-person"></i> مشخصات فردی</div>
                <div class="form-grid-3 p2-mb-16">
                    <div class="form-field">
                        <label>کد پرسنلی *</label>
                        <Pay2NumericInput @bind-Value="CurrentEmp.EMP_CODE" MaxLength="10" />
                    </div>
                    <div class="form-field">
                        <label>نام *</label>
                        <input class="pay2-input" type="text" @bind="CurrentEmp.FIRST_NAME" />
                    </div>
                    <div class="form-field">
                        <label>نام خانوادگی *</label>
                        <input class="pay2-input" type="text" @bind="CurrentEmp.LAST_NAME" />
                    </div>
                </div>

                <div class="form-grid-3 p2-mb-16">
                    <div class="form-field">
                        <label>کد ملی</label>
                        <Pay2NumericInput @bind-Value="CurrentEmp.NATIONAL_CODE" MaxLength="10" />
                    </div>
                    <div class="form-field">
                        <label>تاریخ تولد (شمسی)</label>
                        <Pay2NumericInput @bind-Value="BirthDateStr" InputMode="Pay2NumericInput.NumericInputMode.PersianDate" Placeholder="13600101" Direction="ltr" />
                    </div>
                    <div class="form-field">
                        <label>تأهل</label>
                        <Pay2Select TItem="LookupDto<byte>" TValue="byte" Items="MaritalOptions" @bind-Value="CurrentEmp.MARITAL" TextSelector="x => x.Name" ValueSelector="x => x.Id" Clearable="false" />
                    </div>
                </div>

                <div class="p2-sub-card-title p2-mt-24"><i class="bi bi-briefcase"></i> اشتغال و حسابداری</div>

                <!-- اضافه شدن فیلد شغل در اینجا -->
                <div class="form-grid-3 p2-mb-16">
                    <div class="form-field">
                        <label>کارگاه محل خدمت *</label>
                        <Pay2Select TItem="Pay2WorkshopDto" TValue="int" Items="Workshops" @bind-Value="CurrentEmp.WS_ID" TextSelector="x => x.WS_NAME" ValueSelector="x => x.WS_ID" Clearable="false" />
                    </div>
                    <div class="form-field">
                        <label>شغل پرسنل (اختیاری)</label>
                        <Pay2Select TItem="LookupDto<int>" TValue="int?"
                                    SearchItems="SearchJobsAsync"
                                    Items="Init_JOB"
                                    @bind-Value="CurrentEmp.JOB_ID"
                                    TextSelector="x => x.Name"
                                    ValueSelector="x => x.Id"
                                    Placeholder="جستجوی عنوان شغل..."
                                    Clearable="true" Editable="true" />
                    </div>
                    <div class="form-field">
                        <label>تاریخ شروع به کار *</label>
                        <Pay2NumericInput @bind-Value="HireDateStr" InputMode="Pay2NumericInput.NumericInputMode.PersianDate" Placeholder="14030101" Direction="ltr" />
                    </div>
                </div>

                <div class="form-grid-3 p2-mb-16">
                    <div class="form-field" style="grid-column: span 3;">
                        <label>کد تفصیلی حسابداری (مساعده)</label>
                        <Pay2Select TItem="LookupDto<string>" TValue="string"
                                    SearchItems="SearchAccountsAsync"
                                    Items="Init_ACC_T"
                                    @bind-Value="CurrentEmp.ACC_T"
                                    TextSelector="@(x => $"\u200E{x.Id}\u200E  -  {x.Name}")"
                                    ValueSelector="@(x => x.Id)"
                                    Placeholder="جستجوی کد تفصیلی پرسنل..."
                                    Clearable="true" Editable="true" />
                    </div>
                </div>

                <div class="form-grid-2 p2-mt-24">
                    <div class="form-field">
                        <div class="pay2-wpf-checkbox-box">
                            <label class="pay2-wpf-checkbox-label">
                                <input type="checkbox" @bind="CurrentEmp.IS_ACTIVE" /> پرسنل فعال است (محاسبه حقوق)
                            </label>
                        </div>
                    </div>
                </div>

                <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:24px;">
                    <button class="btn-outline-pay2" @onclick="CloseModals">انصراف</button>
                    <button class="btn-primary-pay2" @onclick="SaveEmployee" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="p2-spinner"></span>
                        }
                        else
                        {

                            <span>ذخیره پرسنل</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    bool IsLoading = true;
    bool IsSaving = false;
    bool ShowEmpModal = false;

    List<Pay2EmployeeDto> Employees = new();
    List<Pay2WorkshopDto> Workshops = new();
    List<LookupDto<int>> Jobs = new(); // اضافه شدن متغیر مشاغل
    Pay2EmployeeDto CurrentEmp = new();

    string? BirthDateStr;
    string? HireDateStr;

    List<LookupDto<byte>> MaritalOptions = new() { new((byte)1, "متأهل"), new((byte)2, "مجرد") };
    List<LookupDto<string>> Init_ACC_T = new();
    List<LookupDto<int>> Init_JOB = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var wsTask = WorkshopApi.GetWorkshopsAsync();
            var empTask = EmployeeApi.GetEmployeesAsync();

            await Task.WhenAll(wsTask, empTask);

            Workshops = wsTask.Result;
            Employees = empTask.Result;
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { IsLoading = false; }
    }
    // ۳. این متد را برای جستجوی کامپوننت Pay2Select اضافه کنید:
    async Task<IEnumerable<LookupDto<int>>> SearchJobsAsync(string? searchTerm, CancellationToken cancellationToken)
    {
        return await EmployeeApi.GetJobsLookupAsync(searchTerm);
    }

    void OpenNewEmpModal()
    {
        CurrentEmp = new Pay2EmployeeDto { IS_ACTIVE = true, HIRE_DATE = long.Parse(Safir.Shared.Utility.CL_Tarikh.GetCurrentPersianDateAsLong().ToString()) };
        HireDateStr = CurrentEmp.HIRE_DATE.ToString();
        BirthDateStr = "";
        Init_JOB.Clear(); // اضافه شد
        Init_ACC_T.Clear();
        ShowEmpModal = true;
    }

    async Task OpenEditEmpModal(Pay2EmployeeDto emp)
    {
        CurrentEmp = System.Text.Json.JsonSerializer.Deserialize<Pay2EmployeeDto>(System.Text.Json.JsonSerializer.Serialize(emp))!;
        HireDateStr = CurrentEmp.HIRE_DATE.ToString();
        BirthDateStr = CurrentEmp.BIRTH_DATE?.ToString();

        Init_ACC_T.Clear();
        if (!string.IsNullOrEmpty(CurrentEmp.ACC_T))
        {
            var res = await LookupService.GetCustomerLookupAsync(CurrentEmp.ACC_T);
            if (res != null && res.Any(x => x.Id == CurrentEmp.ACC_T)) Init_ACC_T.Add(res.First(x => x.Id == CurrentEmp.ACC_T));
            else Init_ACC_T.Add(new LookupDto<string>(CurrentEmp.ACC_T, "حساب نامشخص"));
        }

        Init_JOB.Clear();
        if (CurrentEmp.JOB_ID.HasValue && !string.IsNullOrEmpty(emp.JobName))
        {
            Init_JOB.Add(new LookupDto<int>(CurrentEmp.JOB_ID.Value, emp.JobName));
        }

        ShowEmpModal = true;
    }

    void CloseModals()
    {
        ShowEmpModal = false;
    }

    async Task SaveEmployee()
    {
        if (string.IsNullOrWhiteSpace(CurrentEmp.EMP_CODE) || string.IsNullOrWhiteSpace(CurrentEmp.FIRST_NAME))
        {
            Snackbar.Add("کد پرسنلی و نام الزامی است.", Severity.Warning); return;
        }
        if (CurrentEmp.WS_ID <= 0)
        {
            Snackbar.Add("انتخاب کارگاه الزامی است.", Severity.Warning); return;
        }

        long.TryParse(HireDateStr?.Replace("/", ""), out long hDate);
        long.TryParse(BirthDateStr?.Replace("/", ""), out long bDate);
        CurrentEmp.HIRE_DATE = hDate > 13000000 ? hDate : long.Parse(Safir.Shared.Utility.CL_Tarikh.GetCurrentPersianDateAsLong().ToString());
        CurrentEmp.BIRTH_DATE = bDate > 13000000 ? bDate : null;

        IsSaving = true;
        try
        {
            await EmployeeApi.SaveEmployeeAsync(CurrentEmp);
            Snackbar.Add("پرسنل با موفقیت ذخیره شد.", Severity.Success);
            CloseModals();
            await LoadData();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { IsSaving = false; }
    }

    async Task<IEnumerable<LookupDto<string>>> SearchAccountsAsync(string? searchTerm, CancellationToken cancellationToken)
    {
        var result = await LookupService.GetCustomerLookupAsync(searchTerm, cancellationToken);
        return result ?? Enumerable.Empty<LookupDto<string>>();
    }

    void OpenDecreeModal(Pay2EmployeeDto emp)
    {
        Snackbar.Add("مدیریت احکام به زودی متصل می‌شود...", Severity.Info);
    }
}