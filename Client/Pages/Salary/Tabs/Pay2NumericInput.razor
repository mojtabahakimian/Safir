@implements IAsyncDisposable
@inject IJSRuntime JS

@using System.Globalization
@using System.Linq
@using System.Text

<input @ref="_inputRef"
       class="@InputClass"
       type="text"
       value="@_displayText"
       maxlength="@EffectiveMaxLength"
       inputmode="@InputModeValue"
       autocomplete="off"
       placeholder="@Placeholder"
       disabled="@Disabled"
       readonly="@ReadOnly"
       dir="@Direction"
       title="@ToolTip"
       @oninput="HandleInputAsync"
       @onblur="HandleBlurAsync"
       @onfocus="HandleFocusAsync"
       @onkeydown="HandleKeyDownAsync" />

@code {
    public enum NumericInputMode { None, Amount, PersianDate, Percentage, HoursMinutes }

    private ElementReference _inputRef;
    private IJSObjectReference? _module;

    private string? _displayText;
    private string? _lastParameterValue;
    private string? _lastValidValue;

    private bool _focused;
    private bool _disposed;
    private bool _jsGuardLoaded;

    string? _valueOnFocus; // 🟢 نگهداری مقدار اولیه سلول
    private int _lastEffectiveMaxLength = -1;
    private int _lastMaxDecimalPlaces = -1;
    private NumericInputMode _lastInputMode = (NumericInputMode)(-1);
    private bool _lastThreeTwoZero;

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    [Parameter] public NumericInputMode InputMode { get; set; } = NumericInputMode.None;
    [Parameter] public int MaxLength { get; set; } = 20;
    [Parameter] public bool IsDigitGroupActive { get; set; }
    [Parameter] public bool ThreeTwoZero { get; set; }
    [Parameter] public int MaxDecimalPlaces { get; set; } = 2;
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public string Direction { get; set; } = "rtl";
    [Parameter] public EventCallback<FocusEventArgs> OnBlur { get; set; }
    [Parameter] public EventCallback<FocusEventArgs> OnFocus { get; set; }
    [Parameter] public string? ToolTip { get; set; }

    private int SafeMaxLength => Math.Max(0, MaxLength);
    private int SafeMaxDecimalPlaces => Math.Max(0, MaxDecimalPlaces);

    private string InputClass => string.IsNullOrWhiteSpace(CssClass)
        ? "pay2-input"
        : $"pay2-input {CssClass}";

    private string InputModeValue => InputMode is NumericInputMode.Percentage or NumericInputMode.HoursMinutes ? "decimal" : "numeric";

    private int? EffectiveMaxLength => InputMode switch
    {
        NumericInputMode.PersianDate => 8,
        NumericInputMode.Percentage => SafeMaxLength > 0
            ? SafeMaxLength + (SafeMaxDecimalPlaces > 0 ? SafeMaxDecimalPlaces + 1 : 0)
            : null,
        _ => SafeMaxLength > 0 ? SafeMaxLength : null
    };

    protected override void OnParametersSet()
    {
        var normalizedParameter = Normalize(Value);

        if (!_focused && _lastParameterValue != normalizedParameter)
        {
            _lastParameterValue = normalizedParameter;

            if (IsValidFinalValue(normalizedParameter))
                _lastValidValue = normalizedParameter;

            _displayText = FormatForDisplay(normalizedParameter);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed)
            return;

        if (firstRender)
        {
            try
            {
                // نسخه‌گذاری برای ابطال کش مرورگر پس از تغییر گارد ورودی (پشتیبانی از «:»)
                _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/pay2-input-guards.js?v=14050323-1");
                _jsGuardLoaded = true;
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[Pay2NumericInput] JS Load Error: {ex.Message}");
                return;
            }
        }

        var effectiveLen = EffectiveMaxLength ?? 0;

        if (_jsGuardLoaded &&
            (_lastEffectiveMaxLength != effectiveLen ||
             _lastInputMode != InputMode ||
             _lastMaxDecimalPlaces != SafeMaxDecimalPlaces ||
             _lastThreeTwoZero != ThreeTwoZero))
        {
            _lastEffectiveMaxLength = effectiveLen;
            _lastInputMode = InputMode;
            _lastMaxDecimalPlaces = SafeMaxDecimalPlaces;
            _lastThreeTwoZero = ThreeTwoZero;

            await ReAttachGuardAsync();
        }
    }

    private async Task ReAttachGuardAsync()
    {
        if (_disposed || _module is null)
            return;

        try
        {
            await _module.InvokeVoidAsync("attachInputGuard", _inputRef, new
            {
                maxLength = EffectiveMaxLength ?? 0,
                allowDecimal = InputMode is NumericInputMode.Percentage or NumericInputMode.HoursMinutes,
                allowTime = InputMode == NumericInputMode.HoursMinutes,
                maxDecimalPlaces = SafeMaxDecimalPlaces,
                threeTwoZero = ThreeTwoZero && InputMode != NumericInputMode.PersianDate,
                persianDate = InputMode == NumericInputMode.PersianDate
            });
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Pay2NumericInput] ReAttachGuard Error: {ex.Message}");
        }
    }

    private async Task HandleInputAsync(ChangeEventArgs e)
    {
        var normalized = Normalize(e.Value?.ToString());

        if (InputMode == NumericInputMode.PersianDate && normalized?.Length > 8)
            normalized = normalized[..8];

        if (InputMode is NumericInputMode.Percentage or NumericInputMode.HoursMinutes)
            normalized = LimitDecimalPlaces(normalized, SafeMaxDecimalPlaces);

        _displayText = normalized;

        if (_lastParameterValue != normalized)
        {
            _lastParameterValue = normalized;
            await ValueChanged.InvokeAsync(normalized);
        }
    }

    async Task HandleFocusAsync(FocusEventArgs e)
    {
        _focused = true;
        _valueOnFocus = _displayText; // 🟢 ذخیره مقدار قبل از شروع تایپ

        _displayText = Normalize(_lastParameterValue);
        if (OnFocus.HasDelegate)
            await OnFocus.InvokeAsync(e);
    }
    private async Task HandleBlurAsync(FocusEventArgs e)
    {
        _focused = false;

        var normalized = Normalize(_displayText);
        var finalValue = FinalizeValue(normalized);

        if (finalValue is null && !string.IsNullOrWhiteSpace(normalized))
            finalValue = _lastValidValue;

        _displayText = FormatForDisplay(finalValue);

        if (_lastParameterValue != finalValue)
        {
            _lastParameterValue = finalValue;
            await ValueChanged.InvokeAsync(finalValue);
        }

        if (IsValidFinalValue(finalValue))
            _lastValidValue = finalValue;

        if (OnBlur.HasDelegate)
            await OnBlur.InvokeAsync(e);
    }
    async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (Disabled || ReadOnly) return;

        // 🟢 اگر کاربر کلید Escape را زد، مقدار قبلی برگردانده شود
        if (e.Key == "Escape")
        {
            _displayText = _valueOnFocus; // برگرداندن متن به حالت اول

            var normalized = Normalize(_displayText);
            var finalValue = FinalizeValue(normalized) ?? _lastValidValue;

            _lastParameterValue = finalValue;
            await ValueChanged.InvokeAsync(finalValue);

            // گرفتن فوکوس از روی سلول برای اتمام عملیات لغو
            try { await JS.InvokeVoidAsync("HTMLElement.prototype.blur.call", _inputRef); } catch { }
        }
    }

    private string? FinalizeValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var inv = CultureInfo.InvariantCulture;

        return InputMode switch
        {
            NumericInputMode.PersianDate => NormalizePersianDate(value),

            NumericInputMode.Amount when decimal.TryParse(value, NumberStyles.Number, inv, out var amt)
                => decimal.Truncate(amt).ToString(inv),

            NumericInputMode.Percentage when decimal.TryParse(value, NumberStyles.Number, inv, out var pct)
                => TruncateDecimal(pct, SafeMaxDecimalPlaces).ToString(inv),

            NumericInputMode.HoursMinutes => NormalizeHoursMinutes(value),

            NumericInputMode.None => value,

            _ => null
        };
    }

    // اعتبارسنجی فرمت «ساعت:دقیقه» (مثال 32:35) یا عدد اعشاری (مثال 32.5)
    private static string? NormalizeHoursMinutes(string value)
    {
        var inv = CultureInfo.InvariantCulture;

        if (value.Contains(':'))
        {
            var parts = value.Split(':');
            if (parts.Length != 2) return null;

            if (!int.TryParse(parts[0], NumberStyles.None, inv, out var h)) return null;

            // «32:» را معادل «32» در نظر می‌گیریم
            if (string.IsNullOrEmpty(parts[1])) return h.ToString(inv);

            if (!int.TryParse(parts[1], NumberStyles.None, inv, out var m)) return null;
            if (m > 59) return null;
            return $"{h}:{m:D2}";
        }

        if (decimal.TryParse(value, NumberStyles.Number, inv, out var dec))
            return TruncateDecimal(dec, 2).ToString(inv);

        return null;
    }

    private bool IsValidFinalValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return true;

        return FinalizeValue(value) is not null;
    }

    private string? FormatForDisplay(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var inv = CultureInfo.InvariantCulture;

        try
        {
            if (InputMode == NumericInputMode.Amount &&
                decimal.TryParse(value, NumberStyles.Number, inv, out var amt))
                return decimal.Truncate(amt).ToString("N0", inv);

            if (InputMode == NumericInputMode.PersianDate)
                return FormatPersianDate(value);

            if (InputMode == NumericInputMode.Percentage &&
                decimal.TryParse(value, NumberStyles.Number, inv, out var pct))
            {
                var format = SafeMaxDecimalPlaces > 0
                    ? "0." + new string('#', SafeMaxDecimalPlaces)
                    : "0";

                return pct.ToString(format, inv);
            }
        }
        catch
        {
            return value;
        }

        return value;
    }

    private string? Normalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var sb = new StringBuilder(value.Length);
        var hasDot = false;

        foreach (var ch in value)
        {
            var digit = ToEnglishDigit(ch);

            if (digit is not null)
            {
                sb.Append(digit.Value);
                continue;
            }

            if (InputMode is NumericInputMode.Percentage or NumericInputMode.HoursMinutes &&
                (ch == '.' || ch == '/' || ch == '٫' || ch == ',') &&
                !hasDot)
            {
                sb.Append('.');
                hasDot = true;
            }

            // در حالت ساعت:دقیقه، کاراکتر «:» به عنوان جداکننده دقیقه مجاز است
            if (InputMode == NumericInputMode.HoursMinutes && ch == ':' && !hasDot)
            {
                sb.Append(':');
                hasDot = true;
            }
        }

        var result = sb.ToString();

        if (InputMode is NumericInputMode.Percentage or NumericInputMode.HoursMinutes)
            result = LimitDecimalPlaces(result, SafeMaxDecimalPlaces);

        if (InputMode == NumericInputMode.PersianDate && result.Length > 8)
            result = result[..8];

        return result;
    }

    private static char? ToEnglishDigit(char ch)
    {
        if (ch >= '0' && ch <= '9')
            return ch;

        const string fa = "۰۱۲۳۴۵۶۷۸۹";
        const string ar = "٠١٢٣٤٥٦٧٨٩";

        var faIndex = fa.IndexOf(ch);
        if (faIndex >= 0)
            return (char)('0' + faIndex);

        var arIndex = ar.IndexOf(ch);
        if (arIndex >= 0)
            return (char)('0' + arIndex);

        return null;
    }

    private static string? LimitDecimalPlaces(string? value, int precision)
    {
        if (string.IsNullOrWhiteSpace(value))
            return value;

        // در فرمت ساعت:دقیقه حداکثر دو رقم بعد از «:» مجاز است
        var colonIndex = value.IndexOf(':');
        if (colonIndex >= 0)
        {
            var allowedColonLength = colonIndex + 1 + 2;
            return value.Length > allowedColonLength ? value[..allowedColonLength] : value;
        }

        var dotIndex = value.IndexOf('.');
        if (dotIndex < 0)
            return value;

        if (precision <= 0)
            return value[..dotIndex];

        var allowedLength = dotIndex + 1 + precision;
        return value.Length > allowedLength ? value[..allowedLength] : value;
    }

    private static string FormatPersianDate(string value)
    {
        var digits = new string(value.Select(ToEnglishDigit).Where(x => x is not null).Select(x => x!.Value).ToArray());

        if (digits.Length <= 4)
            return digits;

        if (digits.Length <= 6)
            return $"{digits[..4]}/{digits[4..]}";

        return $"{digits[..4]}/{digits[4..6]}/{digits[6..Math.Min(8, digits.Length)]}";
    }

    private static string? NormalizePersianDate(string value)
    {
        var digits = new string(value.Select(ToEnglishDigit).Where(x => x is not null).Select(x => x!.Value).ToArray());

        if (digits.Length != 8)
            return null;

        try
        {
            var pc = new PersianCalendar();

            var year = int.Parse(digits[..4], CultureInfo.InvariantCulture);
            var month = int.Parse(digits[4..6], CultureInfo.InvariantCulture);
            var day = int.Parse(digits[6..8], CultureInfo.InvariantCulture);

            if (year < 1200 || year > 1600)
                return null;

            if (month < 1 || month > 12)
                return null;

            if (day < 1 || day > pc.GetDaysInMonth(year, month))
                return null;

            _ = pc.ToDateTime(year, month, day, 0, 0, 0, 0);

            return digits;
        }
        catch
        {
            return null;
        }
    }

    private static decimal TruncateDecimal(decimal value, int precision)
    {
        if (precision <= 0)
            return Math.Truncate(value);

        decimal step = 1m;

        for (var i = 0; i < precision; i++)
            step *= 10m;

        return Math.Truncate(value * step) / step;
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed)
            return;

        _disposed = true;

        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("detachInputGuard", _inputRef);
                await _module.DisposeAsync();
            }
            catch
            {
                // ignored
            }
        }
    }
}