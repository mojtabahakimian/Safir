@using Safir.Shared.Models
@using Safir.Shared.Models.Salary
@using Safir.Client.Components.Reports
@inject Safir.Client.Services.Pay2RunApiService RunApi
@inject Safir.Client.Services.Pay2AttendanceApiService AttApi
@inject Safir.Client.Services.Pay2WorkshopApiService WorkshopApi
@inject ISnackbar Snackbar
@inject MudBlazor.IDialogService DialogService
@inject Safir.Client.Services.ConnectionManagerService ConnectionManager
@inject Microsoft.JSInterop.IJSRuntime JS
@inject Safir.Client.Services.Pay2EmployeeApiService EmployeeApi

<div class="pay2-tab-container">
    <div class="card-custom p2-fade-content">
        <div class="p2-card-header" style="border-bottom: 1px solid var(--p2-border-light); padding-bottom: 16px; margin-bottom: 24px;">
            <h5 style="margin: 0; color: var(--p2-primary);"><i class="bi bi-file-earmark-text"></i> مرکز گزارشات حقوق و دستمزد</h5>
            <div class="p2-text-muted" style="font-size: 12px; margin-top: 5px;">
                تولید و چاپ گزارشات قانونی (بیمه، مالیات و...) برای دوره‌های محاسبه شده
            </div>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 24px; align-items: flex-end;">
            
            <div class="form-field" style="width: 250px;">
                <label>انتخاب کارگاه *</label>
                <Safir.Client.Pages.Salary.Tabs.Pay2Select TItem="Pay2WorkshopDto"
                                                           TValue="int"
                                                           Items="Workshops"
                                                           @bind-Value="SelectedWsId"
                                                           @bind-Value:after="OnWorkshopChangedAsync"
                                                           TextSelector="x => x.WS_NAME"
                                                           ValueSelector="x => x.WS_ID"
                                                           Clearable="false" />
            </div>

            <div class="form-field" style="width: 250px;">
                <label>انتخاب ماه (دوره) *</label>
                <Safir.Client.Pages.Salary.Tabs.Pay2Select TItem="Pay2PeriodLookupDto"
                                                           TValue="long"
                                                           Items="Periods"
                                                           @bind-Value="SelectedPeriodDate"
                                                           TextSelector="x => x.PERIOD_TITLE"
                                                           ValueSelector="x => x.PERIOD_DATE"
                                                           Clearable="false" />
            </div>

            <div style="flex-grow: 1;"></div>
        </div>

        <hr class="p2-divider" style="margin: 24px 0;" />

        <div class="dashboard-top-grid">
            <!-- کارت گزارش لیست بیمه -->
            <div class="card-custom" style="background: var(--p2-bg-main); border: 1px solid var(--p2-border);">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
                    <div class="stat-icon-box" style="background: #e0e7ff; color: #2563eb;">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <div>
                        <h6 style="margin: 0; font-weight: bold;">لیست بیمه تامین اجتماعی</h6>
                        <span class="p2-text-muted" style="font-size: 11px;">تولید PDF بر اساس فرمت قانون ۱۴۰۵</span>
                    </div>
                </div>
                <button class="btn-primary-pay2" style="width: 100%;" @onclick="GenerateInsuranceReport" disabled="@IsProcessing">
                    @if (IsProcessing)
                    {
                        <span class="p2-spinner"></span>
                    }
                    else
                    {
                        <i class="bi bi-printer"></i> <span>چاپ لیست بیمه</span>
                    }
                </button>
            </div>

            <!-- کارت دیسکت بیمه (DBF) -->
            <div class="card-custom" style="background: var(--p2-bg-main); border: 1px solid var(--p2-border);">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
                    <div class="stat-icon-box" style="background: #e0f2fe; color: #0284c7;">
                        <i class="bi bi-save"></i>
                    </div>
                    <div>
                        <h6 style="margin: 0; font-weight: bold;">خروجی بانک (دیسکت بیمه DBF)</h6>
                        <span class="p2-text-muted" style="font-size: 11px;">تولید DSKKAR00 و DSKWOR00</span>
                    </div>
                </div>
                <div style="display:flex; gap:10px; width:100%;">
                    <button class="btn-primary-pay2" style="background-color: #0284c7; border-color: #0284c7; flex:1;" @onclick="GenerateInsuranceDiskette" disabled="@IsProcessing">
                        @if (IsProcessing)
                        {
                            <span class="p2-spinner"></span>
                        }
                        else
                        {
                            <i class="bi bi-download"></i> <span>دریافت فایل ZIP</span>
                        }
                    </button>
                    
                    <button class="btn-outline-pay2" style="color: #0284c7; border-color: #0284c7; padding: 0 16px;" @onclick="OpenDiskettePreview" disabled="@IsProcessing" title="پیش‌نمایش محتوای فایل DBF">
                        <i class="bi bi-eye"></i> پیش‌نمایش
                    </button>
                </div>
            </div>

            <!-- گزارش مانده مرخصی -->
            <div class="card-custom" style="background: var(--p2-bg-main); border: 1px solid var(--p2-border);">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
                    <div class="stat-icon-box" style="background: #dcfce7; color: #10b981;">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <div>
                        <h6 style="margin: 0; font-weight: bold;">گزارش مانده مرخصی سالانه</h6>
                        <span class="p2-text-muted" style="font-size: 11px;">محاسبه استحقاق تا تاریخ روز (Pro-Rata)</span>
                    </div>
                </div>
                
                <div style="margin-bottom: 12px;">
                     <label style="font-size:12px; font-weight:bold; margin-bottom:4px; display:block;">فیلتر پرسنل (اختیاری):</label>
                     <Safir.Client.Pages.Salary.Tabs.Pay2Select TItem="Safir.Shared.Models.LookupDto<int>" TValue="int" 
                                Items="EmployeeLookup" 
                                @bind-Value="SelectedEmpId" 
                                TextSelector="x => x.Name" 
                                ValueSelector="x => x.Id" 
                                Placeholder="همه پرسنل کارگاه"
                                Clearable="true" />
                </div>

                <div style="display:flex; gap:10px; width:100%;">
                    <button class="btn-primary-pay2" style="background-color: #10b981; border-color: #10b981; flex:1;" @onclick="GenerateLeaveReport" disabled="@IsProcessing">
                        @if (IsProcessing) 
                        { 
                            <span class="p2-spinner"></span> 
                        }
                        else 
                        { 
                            <i class="bi bi-file-earmark-excel"></i> <span>فایل اکسل</span> 
                        }
                    </button>
                    
                    <button class="btn-outline-pay2" style="color: #10b981; border-color: #10b981; padding: 0 16px;" @onclick="PrintLeaveReportPdf" disabled="@IsProcessing" title="چاپ PDF">
                        <i class="bi bi-printer"></i> چاپ PDF
                    </button>
                </div>
            </div>

            <!-- جایگاه برای گزارشات آینده -->
            <div class="card-custom" style="background: #f8fafc; border: 1px dashed #cbd5e1; opacity: 0.6;">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
                    <div class="stat-icon-box" style="background: #f1f5f9; color: #94a3b8;">
                        <i class="bi bi-bank"></i>
                    </div>
                    <div>
                        <h6 style="margin: 0; font-weight: bold;">خروجی بانک (دیسکت)</h6>
                        <span class="p2-text-muted" style="font-size: 11px;">به زودی...</span>
                    </div>
                </div>
                <button class="btn-outline-pay2" style="width: 100%;" disabled>
                    <i class="bi bi-download"></i> دریافت فایل
                </button>
            </div>

            <!-- کارت مقایسه ماه‌ها -->
            <div class="card-custom" style="background: var(--p2-bg-main); border: 1px solid var(--p2-border);">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
                    <div class="stat-icon-box" style="background: #f3e8ff; color: #8b5cf6;">
                        <i class="bi bi-arrow-left-right"></i>
                    </div>
                    <div>
                        <h6 style="margin: 0; font-weight: bold;">گزارش مقایسه و تغییرات</h6>
                        <span class="p2-text-muted" style="font-size: 11px;">مقایسه ماهانه حقوق، مالیات و کسورات</span>
                    </div>
                </div>
                <button class="btn-primary-pay2" style="background-color: #8b5cf6; border-color: #8b5cf6; width: 100%;" @onclick="() => ShowCompareModal = true" disabled="@IsProcessing">
                    <i class="bi bi-bar-chart-steps"></i> <span>مشاهده گزارش مقایسه</span>
                </button>
            </div>

            <!-- کارت چاپ لیست مالیات -->
            <div class="card-custom" style="background: var(--p2-bg-main); border: 1px solid var(--p2-border);">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
                    <div class="stat-icon-box" style="background: #fce7f3; color: #db2777;">
                        <i class="bi bi-file-earmark-ruled"></i>
                    </div>
                    <div>
                        <h6 style="margin: 0; font-weight: bold;">مالیات حقوق کارکنان</h6>
                        <span class="p2-text-muted" style="font-size: 11px;">مبتنی بر ماده ۸۶ قانون مالیات‌ها</span>
                    </div>
                </div>
                <button class="btn-primary-pay2" style="background-color: #db2777; border-color: #db2777; width: 100%;" @onclick="GenerateTaxReport" disabled="@IsProcessing">
                    @if (IsProcessing)
                    {
                        <span class="p2-spinner"></span>
                    }
                    else
                    {
                        <i class="bi bi-printer"></i> <span>چاپ لیست مالیات</span>
                    }
                </button>
            </div>

            <!-- 🚀 کارت جدید مالیات حقوق (دارایی) -->
            <div class="card-custom" style="background: var(--p2-bg-main); border: 1px solid var(--p2-border);">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
                    <div class="stat-icon-box" style="background: #fce7f3; color: #db2777;">
                        <i class="bi bi-bank"></i>
                    </div>
                    <div>
                        <h6 style="margin: 0; font-weight: bold;">مالیات حقوق (دارایی)</h6>
                        <span class="p2-text-muted" style="font-size: 11px;">تولید اکسل تجمیعی سالانه و دیسکت استاندارد (WP/WH)</span>
                    </div>
                </div>
                
                <div style="display: flex; align-items: center; gap: 10px; width: 100%;">
                    <!-- دکمه اصلی: اکسل سالانه (بزرگتر) -->
                    <button class="btn-primary-pay2" style="background-color: #db2777; border-color: #db2777; flex: 1.5; padding: 10px;" @onclick="GenerateTaxReportExcel" disabled="@IsProcessing">
                        @if (IsProcessing)
                        {
                            <span class="p2-spinner" style="border-width: 2px;"></span>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-excel" style="font-size: 16px;"></i> <span>اکسل سالانه</span>
                        }
                    </button>
                    
                    <!-- دکمه‌های ثانویه: دیسکت و پیش‌نمایش (با استایل ظریف‌تر) -->
                    <div style="display: flex; flex: 1; gap: 8px;">
                        <button class="btn-outline-pay2 sm" style="color: #db2777; border-color: #fbcfe8; background-color: white; flex: 1; height: 42px;" @onclick="GenerateTaxDiskette" disabled="@IsProcessing" title="دریافت دیسکت متنی (فایل ZIP شامل WP و WH)">
                            <i class="bi bi-file-zip" style="font-size: 16px;"></i> <span>دیسکت TXT</span>
                        </button>

                        <button class="btn-outline-pay2 sm" style="color: #db2777; border-color: #fbcfe8; background-color: white; width: 42px; height: 42px; padding: 0; display: flex; justify-content: center; align-items: center; flex-shrink: 0;" @onclick="OpenTaxDiskettePreview" disabled="@IsProcessing" title="پیش‌نمایش محتوای دیسکت مالیات">
                            <i class="bi bi-eye" style="font-size: 16px; margin: 0;"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- مدال پیش‌نمایش دیسکت بیمه -->
<Safir.Client.Pages.Salary.Tabs.EmployeeComponents.InsuranceDiskettePreviewModal 
    IsOpen="ShowDiskettePreviewModal" 
    RunId="PreviewRunId" 
    OnClose="() => ShowDiskettePreviewModal = false" />

<!-- مدال مقایسه ماه‌ها -->
<Safir.Client.Pages.Salary.Tabs.EmployeeComponents.CompareMonthsModal 
    IsOpen="ShowCompareModal" 
    WsId="SelectedWsId"
    Periods="Periods"
    OnClose="() => ShowCompareModal = false" />

<!-- مدال پیش‌نمایش دیسکت مالیات -->
<Safir.Client.Pages.Salary.Tabs.EmployeeComponents.TaxDiskettePreviewModal 
    IsOpen="ShowTaxDiskettePreviewModal" 
    RunId="PreviewTaxRunId" 
    OnClose="() => ShowTaxDiskettePreviewModal = false" />

@code {
    List<Pay2WorkshopDto> Workshops = new();
    List<Pay2PeriodLookupDto> Periods = new();

    int SelectedWsId;
    long SelectedPeriodDate;
    bool IsProcessing = false;
    bool ShowCompareModal = false;
    int SelectedEmpId = 0;
    List<LookupDto<int>> EmployeeLookup = new();

    bool ShowDiskettePreviewModal = false;
    int PreviewRunId = 0;

    bool ShowTaxDiskettePreviewModal = false;
    int PreviewTaxRunId = 0;

    protected override async Task OnInitializedAsync()
    {
        await ConnectionManager.LoadSettingsAsync();
        try
        {
            Workshops = await WorkshopApi.GetWorkshopsAsync() ?? new();
            if (Workshops.Any())
            {
                SelectedWsId = Workshops.First().WS_ID;
                await LoadPeriodsAsync();
                await LoadEmployeesLookupAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
    }

    async Task OnWorkshopChangedAsync()
    {
        SelectedPeriodDate = 0;
        await LoadPeriodsAsync();
    }

    async Task LoadPeriodsAsync()
    {
        if (SelectedWsId <= 0) return;

        try
        {
            Periods = await AttApi.GetPeriodsAsync(SelectedWsId);
            
            Periods.Insert(0, new Pay2PeriodLookupDto 
            { 
                PERIOD_DATE = 0, 
                PERIOD_TITLE = "همه ماه‌ها (گزارش تجمیعی سال)" 
            });

            if (Periods.Any())
            {
                SelectedPeriodDate = Periods.First().PERIOD_DATE;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("خطا در بارگذاری دوره‌ها: " + ex.Message, MudBlazor.Severity.Error);
        }
    }

    async Task LoadEmployeesLookupAsync()
    {
        try
        {
            EmployeeLookup = await EmployeeApi.GetEmployeesLookupAsync();
        }
        catch { }
    }

    // ─── توابع بیمه تامین اجتماعی ───

    async Task GenerateInsuranceReport()
    {
        if (SelectedWsId <= 0 || SelectedPeriodDate < 0)
        {
            Snackbar.Add("لطفاً کارگاه و ماه را انتخاب کنید.", MudBlazor.Severity.Warning);
            return;
        }

        var period = Periods.FirstOrDefault(p => p.PERIOD_DATE == SelectedPeriodDate);
        if (period == null) return;

        IsProcessing = true;
        try
        {
            int targetRunId = 0;
            string dialogTitle = "لیست بیمه تامین اجتماعی";

            if (SelectedPeriodDate == 0) 
            {
                dialogTitle += " - تجمیعی کل سال";
            }
            else 
            {
                var latestRun = await RunApi.GetLatestRunAsync(period.PER_ID);
                if (latestRun == null)
                {
                    Snackbar.Add("هیچ محاسبه حقوقی برای این ماه انجام نشده است. ابتدا به تب محاسبه حقوق مراجعه کنید.", MudBlazor.Severity.Warning);
                    return;
                }
                targetRunId = latestRun.RUN_ID;
                dialogTitle += $" - {period.PERIOD_TITLE}";
            }

            var parameters = new MudBlazor.DialogParameters
            {
                ["Title"] = dialogTitle,
                ["FetchPdfBytes"] = (Func<Task<byte[]>>)(() => RunApi.GetInsuranceReportPdfAsync(targetRunId, SelectedWsId))
            };

            var options = new MudBlazor.DialogOptions
            {
                MaxWidth = MudBlazor.MaxWidth.ExtraExtraLarge,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };

            DialogService.Show<PdfPreviewDialog>("چاپ لیست بیمه", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    async Task GenerateInsuranceDiskette()
    {
        if (SelectedWsId <= 0 || SelectedPeriodDate <= 0) 
        {
            Snackbar.Add("لطفاً یک ماه مشخص را برای تولید دیسکت انتخاب کنید (حالت تجمیعی مجاز نیست).", MudBlazor.Severity.Warning);
            return;
        }

        var period = Periods.FirstOrDefault(p => p.PERIOD_DATE == SelectedPeriodDate);
        if (period == null) return;

        IsProcessing = true;
        try
        {
            var latestRun = await RunApi.GetLatestRunAsync(period.PER_ID);
            if (latestRun == null)
            {
                Snackbar.Add("هیچ محاسبه حقوقی برای این ماه انجام نشده است.", MudBlazor.Severity.Warning);
                return;
            }

            var bytes = await RunApi.GetInsuranceDisketteZipAsync(latestRun.RUN_ID);
            await JS.InvokeVoidAsync("downloadFileFromBytes", $"Tamin_Diskette_{period.PERIOD_TITLE}.zip", bytes);
            
            Snackbar.Add("دیسکت بیمه (DBF) با موفقیت تولید و دانلود شد.", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    async Task OpenDiskettePreview()
    {
        if (SelectedWsId <= 0 || SelectedPeriodDate <= 0)
        {
            Snackbar.Add("لطفاً یک ماه مشخص را برای پیش‌نمایش دیسکت انتخاب کنید (حالت تجمیعی مجاز نیست).", MudBlazor.Severity.Warning);
            return;
        }

        var period = Periods.FirstOrDefault(p => p.PERIOD_DATE == SelectedPeriodDate);
        if (period == null) return;

        IsProcessing = true;
        try
        {
            var latestRun = await RunApi.GetLatestRunAsync(period.PER_ID);
            if (latestRun == null)
            {
                Snackbar.Add("هیچ محاسبه حقوقی برای این ماه انجام نشده است.", MudBlazor.Severity.Warning);
                return;
            }

            PreviewRunId = latestRun.RUN_ID;
            ShowDiskettePreviewModal = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    // ─── توابع مالیات دارایی ───

    async Task GenerateTaxReport()
    {
        if (SelectedWsId <= 0 || SelectedPeriodDate < 0)
        {
            Snackbar.Add("لطفاً کارگاه و ماه را انتخاب کنید.", MudBlazor.Severity.Warning);
            return;
        }

        var period = Periods.FirstOrDefault(p => p.PERIOD_DATE == SelectedPeriodDate);
        if (period == null) return;

        IsProcessing = true;
        try
        {
            int targetRunId = 0;
            string dialogTitle = "لیست مالیات حقوق";

            if (SelectedPeriodDate == 0) 
            {
                dialogTitle += " - تجمیعی کل سال";
            }
            else 
            {
                var latestRun = await RunApi.GetLatestRunAsync(period.PER_ID);
                if (latestRun == null)
                {
                    Snackbar.Add("هیچ محاسبه حقوقی برای این ماه انجام نشده است.", MudBlazor.Severity.Warning);
                    return;
                }
                targetRunId = latestRun.RUN_ID;
                dialogTitle += $" - {period.PERIOD_TITLE}";
            }

            var parameters = new MudBlazor.DialogParameters
            {
                ["Title"] = dialogTitle,
                ["FetchPdfBytes"] = (Func<Task<byte[]>>)(() => RunApi.GetTaxReportPdfAsync(targetRunId, SelectedWsId))
            };

            var options = new MudBlazor.DialogOptions
            {
                MaxWidth = MudBlazor.MaxWidth.ExtraExtraLarge,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };

            DialogService.Show<PdfPreviewDialog>("چاپ لیست مالیات", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    async Task GenerateTaxReportExcel()
    {
        if (SelectedWsId <= 0 || SelectedPeriodDate < 0)
        {
            Snackbar.Add("لطفاً کارگاه را انتخاب کنید.", MudBlazor.Severity.Warning);
            return;
        }

        IsProcessing = true;
        try
        {
            var bytes = await RunApi.GetAnnualTaxReportExcelAsync(SelectedWsId, SelectedPeriodDate);
            long targetYear = SelectedPeriodDate > 0 ? SelectedPeriodDate / 10000 : 1403; 
            
            await JS.InvokeVoidAsync("downloadFileFromBytes", $"Tax_Report_{targetYear}.xlsx", bytes);
            Snackbar.Add("فایل اکسل اظهارنامه مالیاتی با موفقیت تولید و دانلود شد.", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    async Task GenerateTaxDiskette()
    {
        if (SelectedWsId <= 0 || SelectedPeriodDate <= 0) 
        {
            Snackbar.Add("لطفاً یک ماه مشخص را برای تولید دیسکت مالیات انتخاب کنید (حالت تجمیعی مجاز نیست).", MudBlazor.Severity.Warning);
            return;
        }

        var period = Periods.FirstOrDefault(p => p.PERIOD_DATE == SelectedPeriodDate);
        if (period == null) return;

        IsProcessing = true;
        try
        {
            var latestRun = await RunApi.GetLatestRunAsync(period.PER_ID);
            if (latestRun == null)
            {
                Snackbar.Add("هیچ محاسبه حقوقی برای این ماه انجام نشده است.", MudBlazor.Severity.Warning);
                return;
            }

            var bytes = await RunApi.GetTaxDisketteZipAsync(latestRun.RUN_ID);
            
            long pDate = period.PERIOD_DATE;
            string prefix = $"{pDate / 10000}{(pDate / 100) % 100:D2}";
            await JS.InvokeVoidAsync("downloadFileFromBytes", $"Tax_Diskette_{prefix}.zip", bytes);
            
            Snackbar.Add("دیسکت مالیات (فایل‌های WP و WH) با موفقیت تولید و دانلود شد.", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    async Task OpenTaxDiskettePreview()
    {
        if (SelectedWsId <= 0 || SelectedPeriodDate <= 0)
        {
            Snackbar.Add("لطفاً یک ماه مشخص را برای پیش‌نمایش دیسکت مالیات انتخاب کنید (حالت تجمیعی مجاز نیست).", MudBlazor.Severity.Warning);
            return;
        }

        var period = Periods.FirstOrDefault(p => p.PERIOD_DATE == SelectedPeriodDate);
        if (period == null) return;

        IsProcessing = true;
        try
        {
            var latestRun = await RunApi.GetLatestRunAsync(period.PER_ID);
            if (latestRun == null)
            {
                Snackbar.Add("هیچ محاسبه حقوقی برای این ماه انجام نشده است.", MudBlazor.Severity.Warning);
                return;
            }

            PreviewTaxRunId = latestRun.RUN_ID;
            ShowTaxDiskettePreviewModal = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    // ─── توابع مرخصی ───

    async Task GenerateLeaveReport()
    {
        if (SelectedWsId <= 0) { Snackbar.Add("کارگاه انتخاب نشده.", MudBlazor.Severity.Warning); return; }
        int year = (SelectedPeriodDate > 0) ? (int)(SelectedPeriodDate / 10000) : (Periods.Count > 1 ? (int)(Periods[1].PERIOD_DATE / 10000) : 1403);
        long currentDate = Safir.Shared.Utility.CL_Tarikh.GetCurrentPersianDateAsLong();

        IsProcessing = true;
        try
        {
            var bytes = await EmployeeApi.GetLeaveReportExcelAsync(SelectedWsId, year, SelectedEmpId, currentDate);
            await JS.InvokeVoidAsync("downloadFileFromBytes", $"LeaveBalance_{year}.xlsx", bytes);
            Snackbar.Add("فایل اکسل تولید شد.", MudBlazor.Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, MudBlazor.Severity.Error); }
        finally { IsProcessing = false; }
    }

    void PrintLeaveReportPdf()
    {
        if (SelectedWsId <= 0) { Snackbar.Add("کارگاه انتخاب نشده.", MudBlazor.Severity.Warning); return; }
        int year = (SelectedPeriodDate > 0) ? (int)(SelectedPeriodDate / 10000) : (Periods.Count > 1 ? (int)(Periods[1].PERIOD_DATE / 10000) : 1403);
        long currentDate = Safir.Shared.Utility.CL_Tarikh.GetCurrentPersianDateAsLong();

        var parameters = new MudBlazor.DialogParameters
        {
            ["Title"] = $"گزارش مانده مرخصی تا تاریخ {currentDate}",
            ["FetchPdfBytes"] = (Func<Task<byte[]>>)(() => EmployeeApi.GetLeaveReportPdfAsync(SelectedWsId, year, SelectedEmpId, currentDate))
        };
        DialogService.Show<PdfPreviewDialog>("چاپ مرخصی", parameters, new MudBlazor.DialogOptions { MaxWidth = MudBlazor.MaxWidth.ExtraExtraLarge, FullWidth = true, CloseButton = true });
    }
