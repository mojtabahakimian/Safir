@page "/salary/manage"
@layout EmptyLayout
@using Safir.Client.Pages.Salary.Tabs
@using Safir.Shared.Models.Salary
@using Safir.Client.Services
@using Safir.Shared.Interfaces
@using Safir.Shared.Utility
@inject ConnectionManagerService ConnectionManager
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<style>
    .pay2-search-wrapper > .pay2-quick-search-results {
        position: absolute;
        top: calc(100% + 6px);
        right: 0;
        width: min(360px, 80vw);
        max-height: 360px;
        overflow-y: auto;
        padding: 6px;
        border: 1px solid var(--p2-border);
        border-radius: var(--p2-radius-md);
        background: var(--p2-bg-white);
        box-shadow: var(--p2-shadow-lg);
    }

    .pay2-search-wrapper .pay2-quick-search-result {
        display: flex;
        width: 100%;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border: 0;
        border-radius: var(--p2-radius-sm);
        background: transparent;
        color: var(--p2-text-main);
        text-align: right;
        font-family: var(--p2-font);
    }

    .pay2-search-wrapper .pay2-quick-search-result:hover,
    .pay2-search-wrapper .pay2-quick-search-result:focus-visible {
        background: var(--p2-bg-hover);
        outline: none;
    }

    .pay2-search-wrapper .pay2-quick-search-result > i {
        position: static;
        width: 20px;
        flex: 0 0 20px;
        color: var(--p2-primary);
        text-align: center;
        pointer-events: auto;
    }

    .pay2-search-wrapper .pay2-quick-search-result > span {
        display: flex;
        min-width: 0;
        flex-direction: column;
    }

    .pay2-search-wrapper .pay2-quick-search-result strong {
        font-size: 13px;
        font-weight: 700;
    }

    .pay2-search-wrapper .pay2-quick-search-result small {
        margin-top: 2px;
        color: var(--p2-text-muted);
        font-size: 11px;
    }

    .pay2-search-wrapper > .pay2-quick-search-empty {
        padding: 12px;
        color: var(--p2-text-muted);
        text-align: center;
        font-size: 12px;
    }
</style>

@* ══════════════════════════════════════════════════════════
   Toast — نمایش پیام‌های عملیاتی
   ══════════════════════════════════════════════════════════ *@
@if (IsToastVisible)
{
    <div class="pay2-toast">@ToastMessage</div>
}

@* ══════════════════════════════════════════════════════════
   پوسته اصلی اپلیکیشن
   ══════════════════════════════════════════════════════════ *@
<div class="pay2-app">

    @* ─────────────────────────────────────────
     سایدبار
     ───────────────────────────────────────── *@
    <aside class="pay2-sidebar">

        @* برند / لوگو *@
        <div class="pay2-brand">
            <div class="pay2-brand-icon">P2</div>
            <div>
                <div class="pay2-brand-name">@(_activeDbSettings?.Database ?? "سفیر")</div>
                <div class="pay2-brand-version">@(_activeDbSettings?.Server ?? "...") | v@(AppVersion)</div>
            </div>
        </div>

        @* کارت دوره فعال *@
        <div class="pay2-period-card">
            <div class="pay2-period-label">دوره فعال کارگاه</div>
            <div class="pay2-period-row">
                <div class="pay2-period-value">@GlobalPeriodTitle</div>
                <div class="pay2-period-badge" style="background:@GlobalPeriodColor;">@GlobalPeriodStatus</div>
            </div>
        </div>

        @* منوی ناوبری *@
        <ul class="pay2-menu">

            <li class="pay2-nav-item @(ActiveTab == "dashboard" ? "active" : "")"
                @onclick='() => SetActiveTab("dashboard")'>
                <i class="bi bi-grid-1x2"></i>
                داشبورد
            </li>

            <li class="pay2-nav-item @(ActiveTab == "workshops" ? "active" : "")"
                @onclick='() => SetActiveTab("workshops")'>
                <i class="bi bi-building"></i>
                مدیریت کارگاه‌ها
            </li>

            <li class="pay2-nav-item @(ActiveTab == "employees" ? "active" : "")"
                @onclick='() => SetActiveTab("employees")'>
                <i class="bi bi-people"></i>
                پرسنل و احکام
            </li>

            <li class="pay2-nav-item @(ActiveTab == "attendance" ? "active" : "")"
                @onclick='() => SetActiveTab("attendance")'>
                <i class="bi bi-calendar-check"></i>
                کارکرد پرسنل
            </li>

            <li class="pay2-nav-item @(ActiveTab == "advances" ? "active" : "")"
                @onclick='() => SetActiveTab("advances")'>
                <i class="bi bi-cash-coin"></i>
                مساعده هوشمند
            </li>

            <li class="pay2-nav-item @(ActiveTab == "payroll" ? "active" : "")"
                @onclick='() => SetActiveTab("payroll")'>
                <i class="bi bi-calculator"></i>
                محاسبه حقوق
            </li>

            <li class="pay2-nav-item @(ActiveTab == "settings" ? "active" : "")"
                @onclick='() => SetActiveTab("settings")'>
                <i class="bi bi-gear"></i>
                تنظیمات سیستم
            </li>

            <li class="pay2-nav-item @(ActiveTab == "itemdefs" ? "active" : "")" @onclick='() => SetActiveTab("itemdefs")'>
                <i class="bi bi-list-check"></i>
                آیتم‌های حقوقی
            </li>

            <!-- خط جداکننده -->
            <div style="padding: 0 16px;">
                <hr style="border-color: var(--p2-border-light); margin: 10px 0;" />
            </div>

            <!-- دکمه قالب‌های حکم -->
            <li class="pay2-nav-item" @onclick="OpenTemplateModal">
                <i class="bi bi-file-earmark-text"></i>
                قالب‌های حکم
            </li>


            <!-- دکمه مدیریت مشاغل -->
            <li class="pay2-nav-item" @onclick="OpenJobModal">
                <i class="bi bi-briefcase"></i>
                مدیریت مشاغل
            </li>

            <li class="pay2-nav-item @(ActiveTab == "reports" ? "active" : "")"
                @onclick='() => SetActiveTab("reports")'>
                <i class="bi bi-file-earmark-pdf"></i>
                مرکز گزارشات
            </li>

        </ul>

        @* فوتر سایدبار *@
        <div class="pay2-sidebar-footer">
            <div class="pay2-user-avatar">مد</div>
            <div>
                <div class="pay2-user-name">مدیر سیستم</div>
                <div class="pay2-user-role">کارگاه مرکزی</div>
            </div>
        </div>

    </aside>

    @* ─────────────────────────────────────────
     ناحیه اصلی
     ───────────────────────────────────────── *@
    <main class="pay2-main">

        @* هدر بالای صفحه *@
        <header class="pay2-header">
            <div class="pay2-header-title">@GetTabTitle(ActiveTab)</div>

            <div style="display:flex; align-items:center; gap:12px;">
                <div class="pay2-search-wrapper">
                    <i class="bi bi-search"></i>
                    <input type="text"
                           class="pay2-search-input"
                           placeholder="جستجوی سریع..."
                           value="@QuickSearchTerm"
                           @oninput="OnQuickSearch"
                           @onkeydown="OnQuickSearchKeyDown" />
                    @if (QuickSearchResults.Count > 0)
                    {
                        <div class="pay2-quick-search-results">
                            @foreach (var result in QuickSearchResults)
                            {
                                <button type="button" class="pay2-quick-search-result" @onclick="() => OpenQuickSearchResult(result)">
                                    <i class="bi @result.Icon"></i>
                                    <span>
                                        <strong>@result.Title</strong>
                                        @if (!string.Equals(result.Title, result.MenuTitle, StringComparison.Ordinal))
                                        {
                                            <small>@result.MenuTitle</small>
                                        }
                                    </span>
                                </button>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(QuickSearchTerm))
                    {
                        <div class="pay2-quick-search-results pay2-quick-search-empty">نتیجه‌ای یافت نشد.</div>
                    }
                </div>
                <button class="btn-ghost-pay2"
                        type="button"
                        @onclick="LogoutAsync"
                        style="width:40px; height:40px; border-radius:var(--p2-radius-md);"
                        title="خروج">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </div>
        </header>

        @* محتوای تب‌ها *@
        <div class="pay2-content">

            @* ══ داشبورد ══ *@
            @if (ActiveTab == "dashboard")
            {
                <Safir.Client.Pages.Salary.Tabs.DashboardTab OnNavigate="SetActiveTab"
                                                             OnDashboardDataLoaded="UpdateGlobalSidebar" />
            }

            @* ══ مدیریت کارگاه‌ها ══ *@

            @if (ActiveTab == "workshops")
            {
                <WorkshopTab OnToast="ShowToastAsync" />
            }

            @* پرسنل و احکام *@

            @if (ActiveTab == "employees")
            {
                <EmployeeTab />
            }

            <Safir.Client.Pages.Salary.Tabs.EmployeeComponents.ItemTemplateModal IsOpen="ShowTemplateModal"
                                                                                 OnClose="() => ShowTemplateModal = false"
                                                                                 OnManageLines="OpenTemplateLinesModal" />

            <Safir.Client.Pages.Salary.Tabs.EmployeeComponents.ItemTemplateLineModal IsOpen="ShowTemplateLineModal"
                                                                                     MasterTemplateId="SelectedTmplForLines.TMPL_ID"
                                                                                     WorkshopId="SelectedTmplForLines.WS_ID"
                                                                                     MasterTemplateName="@SelectedTmplForLines.TMPL_NAME"
                                                                                     OnClose="() => ShowTemplateLineModal = false" />

            <Safir.Client.Pages.Salary.Tabs.EmployeeComponents.JobModal IsOpen="ShowJobModal"
                                                                        OnClose="() => ShowJobModal = false" />

            @if (ActiveTab == "attendance")
            {
                <Safir.Client.Pages.Salary.Tabs.AttendanceTab />
            }

            @if (ActiveTab == "advances")
            {
                <Safir.Client.Pages.Salary.Tabs.AdvanceTab />
            }

            @* ══ تب‌های در دست توسعه ══ *@

            @if (ActiveTab == "settings")
            {
                <Safir.Client.Pages.Salary.Tabs.SettingsTab />
            }
            @if (ActiveTab == "itemdefs")
            {
                <Safir.Client.Pages.Salary.Tabs.ItemDefTab />
            }
            @if (ActiveTab == "payroll")
            {
                <Safir.Client.Pages.Salary.Tabs.PayrollTab />
            }
            @if (ActiveTab == "reports")
            {
                <Safir.Client.Pages.Salary.Tabs.ReportsTab />
            }
            @if (ActiveTab != "dashboard" &&
                        ActiveTab != "workshops" &&
                        ActiveTab != "employees" &&
                        ActiveTab != "attendance" &&
                        ActiveTab != "advances" &&
                        ActiveTab != "itemdefs" &&
                        ActiveTab != "reports" &&    // <--- این خط اضافه شود
                        ActiveTab != "payroll" &&
                        ActiveTab != "settings")
            {
                <div class="pay2-tab-container"
                     style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%;">
                    <div class="p2-empty-state">
                        <i class="bi bi-tools"></i>
                        <h4>«@GetTabTitle(ActiveTab)»</h4>
                        <p>این بخش در حال توسعه است و به‌زودی اضافه می‌شود.</p>
                    </div>
                </div>
            }

        </div>
    </main>
</div>

@code {

    // ══════════════════════════════════════════
    // State
    // ══════════════════════════════════════════

    private Safir.Shared.Models.DbConnectionSettings? _activeDbSettings;
    private string ActiveTab = "dashboard";
    private bool IsToastVisible = false;
    private string ToastMessage = string.Empty;
    private int _toastVersion = 0;
    private string AppVersion = "1.0.20"; // اضافه شدن فیلد نگهداری ورژن
    private string QuickSearchTerm = string.Empty;

    private static readonly IReadOnlyList<QuickSearchEntry> QuickSearchEntries = new[]
    {
        new QuickSearchEntry("داشبورد", "داشبورد", "dashboard", "bi-grid-1x2"),
        new QuickSearchEntry("مدیریت کارگاه‌ها", "مدیریت کارگاه‌ها", "workshops", "bi-building"),
        new QuickSearchEntry("لیست کارگاه‌ها", "مدیریت کارگاه‌ها", "workshops", "bi-building"),
        new QuickSearchEntry("تنظیم حساب‌های کارگاه", "مدیریت کارگاه‌ها", "workshops", "bi-bank"),
        new QuickSearchEntry("پرسنل و احکام", "پرسنل و احکام", "employees", "bi-people"),
        new QuickSearchEntry("مدیریت پرسنل", "پرسنل و احکام", "employees", "bi-person-vcard"),
        new QuickSearchEntry("احکام پرسنلی", "پرسنل و احکام", "employees", "bi-file-earmark-text"),
        new QuickSearchEntry("قراردادهای پرسنل", "پرسنل و احکام", "employees", "bi-file-text"),
        new QuickSearchEntry("ثبت مرخصی", "پرسنل و احکام", "employees", "bi-calendar-plus"),
        new QuickSearchEntry("مانده مرخصی", "پرسنل و احکام", "employees", "bi-calendar-check"),
        new QuickSearchEntry("وام پرسنلی", "پرسنل و احکام", "employees", "bi-cash-coin"),
        new QuickSearchEntry("تسویه حساب", "پرسنل و احکام", "employees", "bi-door-open"),
        new QuickSearchEntry("کارکرد پرسنل", "کارکرد پرسنل", "attendance", "bi-calendar-check"),
        new QuickSearchEntry("دوره‌های کارکرد", "کارکرد پرسنل", "attendance", "bi-calendar3"),
        new QuickSearchEntry("ثبت کارکرد ماهانه", "کارکرد پرسنل", "attendance", "bi-pencil-square"),
        new QuickSearchEntry("مساعده هوشمند", "مساعده هوشمند", "advances", "bi-cash-coin"),
        new QuickSearchEntry("گزارش مساعده", "مساعده هوشمند", "advances", "bi-table"),
        new QuickSearchEntry("استثناهای مساعده", "مساعده هوشمند", "advances", "bi-slash-circle"),
        new QuickSearchEntry("محاسبه حقوق", "مدیریت اجرای حقوق", "payroll", "bi-calculator"),
        new QuickSearchEntry("اجرای موتور محاسبه", "مدیریت اجرای حقوق", "payroll", "bi-gear"),
        new QuickSearchEntry("فیش‌های حقوق", "مدیریت اجرای حقوق", "payroll", "bi-receipt"),
        new QuickSearchEntry("تنظیمات سیستم", "تنظیمات سیستم", "settings", "bi-gear"),
        new QuickSearchEntry("پیکربندی حقوق", "تنظیمات سیستم", "settings", "bi-sliders"),
        new QuickSearchEntry("پله‌های مالیاتی", "تنظیمات سیستم", "settings", "bi-bar-chart-steps"),
        new QuickSearchEntry("آیتم‌های حقوقی", "آیتم‌های حقوقی", "itemdefs", "bi-list-check"),
        new QuickSearchEntry("تعریف آیتم حقوقی", "آیتم‌های حقوقی", "itemdefs", "bi-plus-square"),
        new QuickSearchEntry("قالب‌های حکم", "قالب‌های حکم", "templates", "bi-file-earmark-text"),
        new QuickSearchEntry("مدیریت مشاغل", "مدیریت مشاغل", "jobs", "bi-briefcase"),
        new QuickSearchEntry("مرکز گزارشات", "مرکز گزارشات", "reports", "bi-file-earmark-pdf"),
        new QuickSearchEntry("لیست بیمه تامین اجتماعی", "مرکز گزارشات", "reports", "bi-shield-check"),
        new QuickSearchEntry("دیسکت بیمه", "مرکز گزارشات", "reports", "bi-floppy"),
        new QuickSearchEntry("گزارش مانده مرخصی", "مرکز گزارشات", "reports", "bi-calendar-check"),
        new QuickSearchEntry("مالیات حقوق", "مرکز گزارشات", "reports", "bi-receipt"),
        new QuickSearchEntry("گزارش مقایسه و تغییرات", "مرکز گزارشات", "reports", "bi-bar-chart-steps")
    };

    private IReadOnlyList<QuickSearchEntry> QuickSearchResults
    {
        get
        {
            var term = QuickSearchTerm.ToStandardSearchText();
            if (string.IsNullOrWhiteSpace(term))
                return Array.Empty<QuickSearchEntry>();

            return QuickSearchEntries
                .Where(x => x.SearchText.Contains(term, StringComparison.Ordinal))
                .Take(10)
                .ToList();
        }
    }

    // ──────────────────────────────────────────
    // داده‌های placeholder داشبورد
    // (بعداً از API واقعی جایگزین می‌شود)
    // ──────────────────────────────────────────

    string GlobalPeriodTitle = "در حال بارگذاری...";
    string GlobalPeriodStatus = "...";
    string GlobalPeriodColor = "var(--p2-bg-main)";

    void UpdateGlobalSidebar(Safir.Shared.Models.Salary.Pay2DashboardDataDto data)
    {
        if (data != null && data.LatestPeriodDate > 0)
        {
            GlobalPeriodTitle = data.PeriodTitle;
            GlobalPeriodStatus = data.PeriodStatusText;
            GlobalPeriodColor = data.PeriodStatus == 1 ? "var(--p2-warning-bg)" : "var(--p2-success-bg)";
        }
        else
        {
            GlobalPeriodTitle = "دوره‌ای یافت نشد";
            GlobalPeriodStatus = "خالی";
            GlobalPeriodColor = "var(--p2-danger-bg)";
        }
        StateHasChanged();
    }

    // ══════════════════════════════════════════
    // Lifecycle
    // ══════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        // 🚀 خواندن اتوماتیک ورژن نرم‌افزار از Assembly
        try
        {
            var version = System.Reflection.Assembly.GetExecutingAssembly().GetName().Version;
            if (version != null)
            {
                AppVersion = version.ToString();
            }
        }
        catch { }

        await ConnectionManager.LoadSettingsAsync();
        _activeDbSettings = await ConnectionManager.GetEffectiveDbSettingsAsync();
    }

    // ══════════════════════════════════════════
    // ناوبری تب‌ها
    // ══════════════════════════════════════════

    private void SetActiveTab(string tabName)
    {
        if (ActiveTab == tabName) return;
        ActiveTab = tabName;
    }

    private void OnQuickSearch(ChangeEventArgs args)
    {
        QuickSearchTerm = args.Value?.ToString() ?? string.Empty;
    }

    private void OnQuickSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
            QuickSearchTerm = string.Empty;
        else if (args.Key == "Enter" && QuickSearchResults.FirstOrDefault() is { } firstResult)
            OpenQuickSearchResult(firstResult);
    }

    private void OpenQuickSearchResult(QuickSearchEntry result)
    {
        QuickSearchTerm = string.Empty;

        if (result.Target == "templates")
            OpenTemplateModal();
        else if (result.Target == "jobs")
            OpenJobModal();
        else
            SetActiveTab(result.Target);
    }

    private async Task LogoutAsync()
    {
        try
        {
            await AuthService.Logout();
        }
        finally
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
        }
    }

    private static string GetTabTitle(string tabName) => tabName switch
    {
        "dashboard" => "داشبورد",
        "workshops" => "مدیریت کارگاه‌ها",
        "employees" => "پرسنل و احکام",
        "attendance" => "کارکرد پرسنل",
        "advances" => "مساعده هوشمند",
        "payroll" => "مدیریت اجرای حقوق",
        "reports" => "مرکز گزارشات", // <--- این خط اضافه شود
        "settings" => "تنظیمات سیستم",
        "itemdefs" => "آیتم‌های حقوقی",
        _ => "سیستم حقوق و دستمزد"
    };

    // ══════════════════════════════════════════
    // Toast — با versioning برای جلوگیری از
    // بسته شدن زودهنگام در صورت چند پیام پشت سر هم
    // ══════════════════════════════════════════

    private async Task ShowToastAsync(string message)
    {
        var version = ++_toastVersion;
        ToastMessage = message;
        IsToastVisible = true;
        StateHasChanged();

        await Task.Delay(3200);

        if (version == _toastVersion)
        {
            IsToastVisible = false;
            StateHasChanged();
        }
    }

    bool ShowJobModal = false;
    bool ShowTemplateModal = false;
    bool ShowTemplateLineModal = false;
    Pay2ItemTemplateDto SelectedTmplForLines = new();

    void OpenTemplateModal()
    {
        ShowTemplateModal = true;
    }

    void OpenTemplateLinesModal(Pay2ItemTemplateDto tmpl)
    {
        SelectedTmplForLines = tmpl;
        ShowTemplateLineModal = true;
    }

    void OpenJobModal()
    {
        ShowJobModal = true;
    }

    private sealed class QuickSearchEntry
    {
        public QuickSearchEntry(string title, string menuTitle, string target, string icon)
        {
            Title = title;
            MenuTitle = menuTitle;
            Target = target;
            Icon = icon;
            SearchText = $"{title} {menuTitle}".ToStandardSearchText();
        }

        public string Title { get; }
        public string MenuTitle { get; }
        public string Target { get; }
        public string Icon { get; }
        public string SearchText { get; }
    }
}
